+// --- NAL-aware peek (link protection) ---
+//
+// One process-wide config; data_source reads it on every datagram and
+// CMD_SET_PEEK mutates the two live toggles. Zero-initialised => enabled=false
+// => peek() is a no-op (zero-cost passthrough) until a profile/arg/command
+// arms it. main() calls peek_cfg_init() so the mandatory FEC_CLOSE signal is
+// seeded even when armed later by command.
+static peek_cfg_t g_peek_cfg;
+
+// Run one datagram through peek and emit it. Shared by the SHM drain loop and
+// the UDP recvmsg path so both transports behave identically (and audio/uplink
+// instances, running with peek off, pay nothing). Returns true if transmitted,
+// false if dropped. Re-arms fec_close_ts when a frame-boundary close fires.
+static inline bool peek_emit(Transmitter *t, const uint8_t *buf, size_t rsize,
+                             int fec_timeout, uint64_t &fec_close_ts,
+                             uint32_t &count_peek_dropped, uint32_t &count_peek_closes)
+{
+    peek_outcome_t o = peek(buf, rsize, &g_peek_cfg);
+
+    if (o.action == PEEK_ACT_DROP && g_peek_cfg.drop_enabled)
+    {
+        // Dropped before the FEC block: no send, and signals are not evaluated
+        // (the previous transmitted frame already closed on its own marker).
+        count_peek_dropped += 1;
+        return false;
+    }
+
+    if (o.action == PEEK_ACT_PROTECT)
+    {
+        t->set_tx_level(o.mcs_delta);
+    }
+
+    t->send_packet(buf, rsize, 0);
+
+    if (o.signals & PEEK_SIG_FEC_CLOSE)
+    {
+        // Close the block on the access-unit boundary. Enqueue order matters:
+        // the marked fragment is already in (above), so parity covers it.
+        while (t->send_packet(NULL, 0, WFB_PACKET_FEC_ONLY));
+        if (fec_timeout > 0) fec_close_ts = get_time_ms() + fec_timeout;
+        count_peek_closes += 1;
+    }
+    return true;
+}
