+// wfb_tx per-frame FEC close (peek) — classification engine. See peek.hpp.
+//
+// peek() answers one question: "does this datagram end a video frame?" (RTP
+// marker bit). If so it signals FEC_CLOSE and tx.cpp closes the open FEC block
+// at the frame boundary. Nothing else — the NAL-aware PROTECT/DROP rules and
+// short-tail close were removed.
+
+#include "peek.hpp"
+
+#include <string.h>
+
+void peek_cfg_init(peek_cfg_t *cfg)
+{
+    memset(cfg, 0, sizeof(*cfg));
+    cfg->enabled = false;
+    // Mandatory frame-boundary signal: RTP marker bit = datagram byte 1, 0x80.
+    cfg->sig_rules[0].match.off  = 1;
+    cfg->sig_rules[0].match.mask = 0x80;
+    cfg->sig_rules[0].match.val  = 0x80;
+    cfg->sig_rules[0].signal     = PEEK_SIG_FEC_CLOSE;
+    cfg->n_sig_rules = 1;
+}
+
+bool peek_cfg_set_profile(peek_cfg_t *cfg, const char *profile)
+{
+    peek_cfg_init(cfg);
+    if (!profile || strcmp(profile, "off") == 0) {
+        cfg->enabled = false;
+        return true;
+    }
+    if (strcmp(profile, "close") == 0) {
+        // Armed: the mandatory FEC_CLOSE signal closes every frame's block.
+        cfg->enabled = true;
+        return true;
+    }
+    return false; // unknown
+}
+
+peek_outcome_t peek(const uint8_t *buf, size_t len, const peek_cfg_t *cfg)
+{
+    peek_outcome_t out = { 0 };
+    if (!cfg || !cfg->enabled) return out;
+
+    // Signal rules: accumulate all matches (byte-mask anchored at datagram start).
+    for (uint8_t i = 0; i < cfg->n_sig_rules; i++) {
+        const peek_sig_rule_t *s = &cfg->sig_rules[i];
+        size_t idx = s->match.off;
+        if (idx >= len) continue;
+        if ((buf[idx] & s->match.mask) == s->match.val)
+            out.signals |= s->signal;
+    }
+    return out;
+}
