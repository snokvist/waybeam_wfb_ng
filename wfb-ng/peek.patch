diff --git a/src/peek.cpp b/src/peek.cpp
new file mode 100644
index 0000000..6891eb2
--- /dev/null
+++ b/src/peek.cpp
@@ -0,0 +1,294 @@
+// wfb_tx NAL-aware link protection — classification engine (peek).
+// See peek.hpp for the contract and docs/design/wfb-tx-nal-aware-protection.md.
+
+#include "peek.hpp"
+
+#include <string.h>
+#include <stdlib.h>
+#include <vector>
+
+// HEVC nuh_type values we care about.
+enum {
+    HEVC_TRAIL_N   = 0,
+    HEVC_TRAIL_R   = 1,
+    HEVC_IDR_W_RADL = 19,
+    HEVC_IDR_N_LP  = 20,
+    HEVC_CRA       = 21,
+    HEVC_VPS       = 32,
+    HEVC_SPS       = 33,
+    HEVC_PPS       = 34,
+    HEVC_FU        = 49, // fragmentation unit; real type in nal[2]
+};
+
+// H.264 nal_unit_type values.
+enum {
+    H264_IDR = 5,
+    H264_SPS = 7,
+    H264_PPS = 8,
+    H264_FUA = 28, // fragmentation unit A; real type in nal[1]
+};
+
+static inline uint64_t bit(unsigned t) { return (uint64_t)1u << t; }
+
+// Locate the codec payload (first NAL byte) inside an RTP datagram. Returns a
+// byte offset from buf, or 0 (fail-open to datagram start) if anything is too
+// short to parse.
+static size_t locate_payload(const uint8_t *buf, size_t len)
+{
+    if (len < 12) return 0;                         // not even a fixed RTP header
+    size_t off = 12 + 4 * (size_t)(buf[0] & 0x0F);  // CSRC list
+    if (buf[0] & 0x10) {                            // extension header present
+        if (off + 4 > len) return 0;
+        uint16_t ext_words = (uint16_t)((buf[off + 2] << 8) | buf[off + 3]);
+        off += 4 + 4 * (size_t)ext_words;
+    }
+    if (off >= len) return 0;
+    return off;
+}
+
+// Extract the effective NAL type at nal_off for the configured proto, applying
+// FU indirection so every fragment of an access unit reports the same type.
+// Returns 0xFF when the bytes available are too short to decide.
+static uint8_t nal_type(const uint8_t *buf, size_t len, size_t nal_off, uint8_t proto)
+{
+    size_t avail = (nal_off <= len) ? (len - nal_off) : 0;
+    const uint8_t *nal = buf + nal_off;
+
+    if (proto == PEEK_PROTO_HEVC) {
+        if (avail < 2) return 0xFF;
+        uint8_t t = (uint8_t)((nal[0] >> 1) & 0x3F);
+        if (t == HEVC_FU) {
+            if (avail < 3) return 0xFF;
+            return (uint8_t)(nal[2] & 0x3F); // FU header carries original type
+        }
+        return t;
+    } else { // PEEK_PROTO_H264
+        if (avail < 1) return 0xFF;
+        uint8_t t = (uint8_t)(nal[0] & 0x1F);
+        if (t == H264_FUA) {
+            if (avail < 2) return 0xFF;
+            return (uint8_t)(nal[1] & 0x1F);
+        }
+        return t;
+    }
+}
+
+static bool match_one(const peek_match_t *m, const uint8_t *buf, size_t len,
+                      size_t nal_off, uint8_t t)
+{
+    if (m->kind == PEEK_MATCH_NAL_TYPE) {
+        if (t == 0xFF) return false;       // undecidable type never matches
+        if (t >= 64) return false;          // out of mask range
+        return (m->u.nal.type_mask >> t) & 1u;
+    }
+    // PEEK_MATCH_BYTE_MASK
+    size_t base = (m->u.byte.anchor == PEEK_ANCHOR_DATAGRAM) ? 0 : nal_off;
+    size_t i = base + m->u.byte.off;
+    if (i >= len) return false;
+    return (buf[i] & m->u.byte.mask) == m->u.byte.val;
+}
+
+void peek_cfg_init(peek_cfg_t *cfg)
+{
+    memset(cfg, 0, sizeof(*cfg));
+    cfg->enabled = false;
+    cfg->drop_enabled = false;
+    // Mandatory frame-boundary signal: RTP marker bit = datagram byte 1, 0x80.
+    cfg->sig_rules[0].match.kind = PEEK_MATCH_BYTE_MASK;
+    cfg->sig_rules[0].match.u.byte.anchor = PEEK_ANCHOR_DATAGRAM;
+    cfg->sig_rules[0].match.u.byte.off = 1;
+    cfg->sig_rules[0].match.u.byte.mask = 0x80;
+    cfg->sig_rules[0].match.u.byte.val = 0x80;
+    cfg->sig_rules[0].signal = PEEK_SIG_FEC_CLOSE;
+    cfg->n_sig_rules = 1;
+}
+
+// helpers to append an action rule
+static void add_nal_rule(peek_cfg_t *cfg, uint8_t proto, uint64_t mask,
+                         peek_action_t act, uint8_t delta)
+{
+    if (cfg->n_rules >= PEEK_MAX_RULES) return;
+    peek_rule_t *r = &cfg->rules[cfg->n_rules++];
+    memset(r, 0, sizeof(*r));
+    r->match.kind = PEEK_MATCH_NAL_TYPE;
+    r->match.u.nal.proto = proto;
+    r->match.u.nal.type_mask = mask;
+    r->action = act;
+    r->mcs_delta = delta;
+}
+
+static const uint64_t HEVC_PARAMSETS = bit(HEVC_VPS) | bit(HEVC_SPS) | bit(HEVC_PPS);
+static const uint64_t HEVC_KEY       = bit(HEVC_IDR_W_RADL) | bit(HEVC_IDR_N_LP) | bit(HEVC_CRA);
+
+bool peek_cfg_set_profile(peek_cfg_t *cfg, const char *profile)
+{
+    peek_cfg_init(cfg);
+    if (!profile || strcmp(profile, "off") == 0) {
+        cfg->enabled = false;
+        return true;
+    }
+    if (strcmp(profile, "idr") == 0) {
+        cfg->enabled = true;
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, HEVC_PARAMSETS, PEEK_ACT_PROTECT, 2);
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, HEVC_KEY,       PEEK_ACT_PROTECT, 1);
+        return true;
+    }
+    if (strcmp(profile, "refpred") == 0) {
+        cfg->enabled = true;
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, bit(HEVC_TRAIL_R), PEEK_ACT_PROTECT, 1);
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, bit(HEVC_TRAIL_N), PEEK_ACT_DROP,    0);
+        return true;
+    }
+    if (strcmp(profile, "idr+refpred") == 0) {
+        cfg->enabled = true;
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, HEVC_PARAMSETS,                 PEEK_ACT_PROTECT, 2);
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, HEVC_KEY | bit(HEVC_TRAIL_R),   PEEK_ACT_PROTECT, 1);
+        add_nal_rule(cfg, PEEK_PROTO_HEVC, bit(HEVC_TRAIL_N),              PEEK_ACT_DROP,    0);
+        return true;
+    }
+    return false; // unknown
+}
+
+// Map a NAL-type token to a HEVC/H.264 bit. Recognises a small vocabulary
+// shared by both protocols where it makes sense.
+static bool token_to_mask(uint8_t proto, const char *tok, uint64_t *out)
+{
+    struct { const char *name; uint8_t proto; uint64_t mask; } tbl[] = {
+        { "trail_n", PEEK_PROTO_HEVC, bit(HEVC_TRAIL_N) },
+        { "trail_r", PEEK_PROTO_HEVC, bit(HEVC_TRAIL_R) },
+        { "idr",     PEEK_PROTO_HEVC, bit(HEVC_IDR_W_RADL) | bit(HEVC_IDR_N_LP) },
+        { "cra",     PEEK_PROTO_HEVC, bit(HEVC_CRA) },
+        { "vps",     PEEK_PROTO_HEVC, bit(HEVC_VPS) },
+        { "sps",     PEEK_PROTO_HEVC, bit(HEVC_SPS) },
+        { "pps",     PEEK_PROTO_HEVC, bit(HEVC_PPS) },
+        { "params",  PEEK_PROTO_HEVC, HEVC_PARAMSETS },
+        { "idr",     PEEK_PROTO_H264, bit(H264_IDR) },
+        { "sps",     PEEK_PROTO_H264, bit(H264_SPS) },
+        { "pps",     PEEK_PROTO_H264, bit(H264_PPS) },
+        { "params",  PEEK_PROTO_H264, bit(H264_SPS) | bit(H264_PPS) },
+    };
+    for (size_t i = 0; i < sizeof(tbl) / sizeof(tbl[0]); i++) {
+        if (tbl[i].proto == proto && strcmp(tbl[i].name, tok) == 0) {
+            *out = tbl[i].mask;
+            return true;
+        }
+    }
+    return false;
+}
+
+bool peek_cfg_add_rule(peek_cfg_t *cfg, const char *spec, std::string *err)
+{
+    // <proto>:<action>:<types>[:dN]
+    std::string s(spec ? spec : "");
+    std::vector<std::string> parts;
+    size_t start = 0;
+    for (;;) {
+        size_t c = s.find(':', start);
+        parts.push_back(s.substr(start, c == std::string::npos ? c : c - start));
+        if (c == std::string::npos) break;
+        start = c + 1;
+    }
+    if (parts.size() < 3) { if (err) *err = "expected <proto>:<action>:<types>[:dN]"; return false; }
+
+    uint8_t proto;
+    if (parts[0] == "hevc" || parts[0] == "h265") proto = PEEK_PROTO_HEVC;
+    else if (parts[0] == "h264" || parts[0] == "avc") proto = PEEK_PROTO_H264;
+    else { if (err) *err = "proto must be hevc|h265|h264|avc"; return false; }
+
+    peek_action_t action;
+    if (parts[1] == "pass")    action = PEEK_ACT_PASS;
+    else if (parts[1] == "protect") action = PEEK_ACT_PROTECT;
+    else if (parts[1] == "drop")    action = PEEK_ACT_DROP;
+    else { if (err) *err = "action must be pass|protect|drop"; return false; }
+
+    uint8_t delta = (action == PEEK_ACT_PROTECT) ? 1 : 0;
+    if (parts.size() >= 4 && !parts[3].empty()) {
+        const char *d = parts[3].c_str();
+        if (*d == 'd') d++;
+        if (strncmp(d, "elta", 4) == 0) d += 4; // accept "delta2"
+        char *endp;
+        long v = strtol(d, &endp, 10);
+        if (*endp != '\0' || v < 0 || v > PEEK_MAX_DELTA) {
+            if (err) *err = "delta must be 0..4 (write dN)";
+            return false;
+        }
+        delta = (uint8_t)v;
+    }
+
+    // types is a comma list
+    uint64_t mask = 0;
+    std::string types = parts[2];
+    size_t ts = 0;
+    while (ts <= types.size()) {
+        size_t c = types.find(',', ts);
+        std::string tok = types.substr(ts, c == std::string::npos ? c : c - ts);
+        if (!tok.empty()) {
+            uint64_t m;
+            if (!token_to_mask(proto, tok.c_str(), &m)) {
+                if (err) *err = "unknown NAL token '" + tok + "'";
+                return false;
+            }
+            mask |= m;
+        }
+        if (c == std::string::npos) break;
+        ts = c + 1;
+    }
+    if (mask == 0) { if (err) *err = "no NAL types given"; return false; }
+    if (cfg->n_rules >= PEEK_MAX_RULES) { if (err) *err = "rule table full"; return false; }
+
+    add_nal_rule(cfg, proto, mask, action, delta);
+    cfg->enabled = true; // any explicit rule arms the pipeline
+    return true;
+}
+
+peek_outcome_t peek(const uint8_t *buf, size_t len, const peek_cfg_t *cfg)
+{
+    peek_outcome_t out = { PEEK_ACT_PASS, 0, 0 };
+    if (!cfg || !cfg->enabled) return out;
+
+    size_t nal_off = locate_payload(buf, len);
+    // proto for the NAL decode is taken per-rule; decode lazily by proto.
+    // Most deployments are single-proto, so decode both only if needed.
+    uint8_t t_hevc = 0xFE, t_h264 = 0xFE; // 0xFE = not yet decoded
+
+    // action rules: first match wins
+    for (uint8_t i = 0; i < cfg->n_rules; i++) {
+        const peek_rule_t *r = &cfg->rules[i];
+        uint8_t t = 0xFF;
+        if (r->match.kind == PEEK_MATCH_NAL_TYPE) {
+            uint8_t proto = r->match.u.nal.proto;
+            if (proto == PEEK_PROTO_HEVC) {
+                if (t_hevc == 0xFE) t_hevc = nal_type(buf, len, nal_off, PEEK_PROTO_HEVC);
+                t = t_hevc;
+            } else {
+                if (t_h264 == 0xFE) t_h264 = nal_type(buf, len, nal_off, PEEK_PROTO_H264);
+                t = t_h264;
+            }
+        }
+        if (match_one(&r->match, buf, len, nal_off, t)) {
+            out.action = r->action;
+            out.mcs_delta = r->mcs_delta;
+            break;
+        }
+    }
+
+    // signal rules: accumulate all. (Skipped by the caller for dropped pkts.)
+    for (uint8_t i = 0; i < cfg->n_sig_rules; i++) {
+        const peek_sig_rule_t *r = &cfg->sig_rules[i];
+        uint8_t t = 0xFF;
+        if (r->match.kind == PEEK_MATCH_NAL_TYPE) {
+            uint8_t proto = r->match.u.nal.proto;
+            if (proto == PEEK_PROTO_HEVC) {
+                if (t_hevc == 0xFE) t_hevc = nal_type(buf, len, nal_off, PEEK_PROTO_HEVC);
+                t = t_hevc;
+            } else {
+                if (t_h264 == 0xFE) t_h264 = nal_type(buf, len, nal_off, PEEK_PROTO_H264);
+                t = t_h264;
+            }
+        }
+        if (match_one(&r->match, buf, len, nal_off, t)) {
+            out.signals |= r->signal;
+        }
+    }
+    return out;
+}
diff --git a/src/peek.hpp b/src/peek.hpp
new file mode 100644
index 0000000..f0a8f26
--- /dev/null
+++ b/src/peek.hpp
@@ -0,0 +1,116 @@
+// -*- C++ -*-
+//
+// wfb_tx NAL-aware link protection — classification engine (peek).
+//
+// Self-contained, host-testable. No wfb-ng / libsodium / pcap dependency:
+// peek() is a pure function over a datagram + a config table. The transmit
+// side (radiotap MCS select, FEC close, drop) lives in tx.cpp; this file only
+// answers "what should happen to this datagram?".
+//
+// Design + rationale: docs/design/wfb-tx-nal-aware-protection.md (waybeam_wfb_ng)
+// and waybeam_venc#143 (the canonical spec).
+
+#ifndef WFB_PEEK_HPP
+#define WFB_PEEK_HPP
+
+#include <stdint.h>
+#include <stddef.h>
+#include <string>
+
+// ---- generic matcher, shared by action rules and signal rules ----
+typedef enum {
+    PEEK_MATCH_NAL_TYPE = 0, // decode HEVC/H.264 NAL type, test type_mask
+    PEEK_MATCH_BYTE_MASK,    // raw test: (base[off] & mask) == val
+} peek_match_kind_t;
+
+typedef enum { PEEK_PROTO_HEVC = 0, PEEK_PROTO_H264 = 1 } peek_proto_t;
+
+typedef enum {
+    PEEK_ANCHOR_DATAGRAM = 0, // off measured from datagram byte 0 (RTP header)
+    PEEK_ANCHOR_PAYLOAD,      // off measured from start of codec payload (post-RTP)
+} peek_anchor_t;
+
+typedef struct {
+    peek_match_kind_t kind;
+    union {
+        struct {                 // PEEK_MATCH_NAL_TYPE
+            uint8_t  proto;      // peek_proto_t
+            uint64_t type_mask;  // bit i set => NAL type i matches
+        } nal;
+        struct {                 // PEEK_MATCH_BYTE_MASK
+            uint8_t  anchor;     // peek_anchor_t
+            uint16_t off;
+            uint8_t  mask;
+            uint8_t  val;        // match iff (byte & mask) == val
+        } byte;
+    } u;
+} peek_match_t;
+
+// ---- outcome 1: per-packet transmit action (first match wins) ----
+typedef enum {
+    PEEK_ACT_PASS = 0,   // transmit at base MCS
+    PEEK_ACT_PROTECT,    // transmit at base_mcs - mcs_delta
+    PEEK_ACT_DROP,       // discard before FEC (if drop_enabled)
+} peek_action_t;
+
+typedef struct {
+    peek_match_t  match;
+    peek_action_t action;
+    uint8_t       mcs_delta;     // PROTECT only; steps below base MCS
+} peek_rule_t;
+
+// ---- outcome 2: control signals (accumulate all matches) ----
+typedef enum {
+    PEEK_SIG_FEC_CLOSE = 1u << 0, // close the FEC block at this packet
+} peek_signal_t;
+
+typedef struct {
+    peek_match_t match;
+    uint16_t     signal;         // bitmask of peek_signal_t
+} peek_sig_rule_t;
+
+#define PEEK_MAX_RULES      8
+#define PEEK_MAX_SIG_RULES  4
+// Largest mcs_delta any rule may request; bounds the prebuilt radiotap cache.
+#define PEEK_MAX_DELTA      4
+
+typedef struct {
+    bool            enabled;       // master pipeline toggle (live)
+    bool            drop_enabled;  // arm DROP-action rules (live)
+    uint8_t         base_mcs;      // mirror of the configured MCS (observability)
+    peek_rule_t     rules[PEEK_MAX_RULES];
+    uint8_t         n_rules;
+    peek_sig_rule_t sig_rules[PEEK_MAX_SIG_RULES]; // seeded with mandatory FEC_CLOSE
+    uint8_t         n_sig_rules;
+} peek_cfg_t;
+
+// Result of classifying one datagram.
+typedef struct {
+    peek_action_t action;   // PASS / PROTECT / DROP
+    uint8_t       mcs_delta; // valid when action == PROTECT
+    uint16_t      signals;  // bitmask of peek_signal_t
+} peek_outcome_t;
+
+// ---- public API ----
+
+// Zero a cfg and seed the mandatory frame-boundary FEC_CLOSE signal rule
+// (RTP marker bit). After this the signal table is never empty. enabled is
+// left false; caller flips it via profile/args/CMD_SET_PEEK.
+void peek_cfg_init(peek_cfg_t *cfg);
+
+// Expand a startup profile name into the action table (and re-seed the
+// mandatory signal). Recognised: "off", "idr", "refpred", "idr+refpred".
+// Returns true on success, false on an unknown profile (cfg left as init).
+bool peek_cfg_set_profile(peek_cfg_t *cfg, const char *profile);
+
+// Append/override one granular action rule from a --peek-rule spec, e.g.
+//   "hevc:protect:idr,cra:d1"   "h264:drop:trail_n"   "hevc:pass:vps"
+// Δ may be written "d2", "delta2", or omitted (defaults to 1 for protect).
+// Returns true on success. On parse error returns false and sets *err.
+bool peek_cfg_add_rule(peek_cfg_t *cfg, const char *spec, std::string *err);
+
+// Classify one datagram. buf/len is the full datagram as it sits in the ring /
+// recv buffer (RTP header included). Fail-open: short/unparseable => PASS, 0.
+peek_outcome_t peek(const uint8_t *buf, size_t len, const peek_cfg_t *cfg);
+
+#endif // WFB_PEEK_HPP
diff --git a/src/test_peek.cpp b/src/test_peek.cpp
new file mode 100644
index 0000000..38c2c21
--- /dev/null
+++ b/src/test_peek.cpp
@@ -0,0 +1,177 @@
+// Host unit test for the NAL-aware peek engine. No hardware, no wfb-ng deps.
+// Build: g++ -std=gnu++11 -o test_peek src/test_peek.cpp src/peek.cpp && ./test_peek
+
+#include "peek.hpp"
+#include <stdio.h>
+#include <string.h>
+#include <vector>
+
+static int g_fail = 0;
+static int g_total = 0;
+
+#define CHECK(cond, msg) do { \
+    g_total++; \
+    if (!(cond)) { g_fail++; printf("FAIL: %s\n", msg); } \
+} while (0)
+
+// Build an RTP datagram: 12-byte header (marker optional) + NAL bytes.
+static std::vector<uint8_t> rtp(bool marker, std::initializer_list<uint8_t> nal)
+{
+    std::vector<uint8_t> p(12, 0);
+    p[0] = 0x80;                       // V=2, no CSRC, no extension
+    p[1] = (uint8_t)((marker ? 0x80 : 0x00) | 0x60); // M | PT=96
+    for (uint8_t b : nal) p.push_back(b);
+    return p;
+}
+
+// HEVC single-NAL first byte for a given nuh_type.
+static uint8_t hevc(uint8_t type) { return (uint8_t)(type << 1); }
+
+static peek_outcome_t run(const peek_cfg_t &cfg, const std::vector<uint8_t> &d)
+{
+    return peek(d.data(), d.size(), &cfg);
+}
+
+int main(void)
+{
+    // ---- profile: idr (HEVC) ----
+    {
+        peek_cfg_t cfg;
+        bool ok = peek_cfg_set_profile(&cfg, "idr");
+        CHECK(ok && cfg.enabled, "idr profile loads");
+
+        // VPS => PROTECT delta 2
+        auto o = run(cfg, rtp(false, { hevc(32), 0x01 }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 2, "idr: VPS protect d2");
+
+        // SPS/PPS also d2
+        o = run(cfg, rtp(false, { hevc(34), 0x01 }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 2, "idr: PPS protect d2");
+
+        // IDR_W_RADL => PROTECT delta 1
+        o = run(cfg, rtp(false, { hevc(19), 0x00 }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "idr: IDR protect d1");
+
+        // CRA => PROTECT delta 1
+        o = run(cfg, rtp(false, { hevc(21), 0x00 }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "idr: CRA protect d1");
+
+        // TRAIL_R => PASS (idr profile leaves non-key frames alone)
+        o = run(cfg, rtp(false, { hevc(1), 0x00 }));
+        CHECK(o.action == PEEK_ACT_PASS, "idr: TRAIL_R pass");
+
+        // marker bit raises FEC_CLOSE regardless of action
+        o = run(cfg, rtp(true, { hevc(1), 0x00 }));
+        CHECK(o.action == PEEK_ACT_PASS && (o.signals & PEEK_SIG_FEC_CLOSE),
+              "idr: marker on TRAIL_R => PASS + FEC_CLOSE");
+
+        // marker clear => no FEC_CLOSE
+        o = run(cfg, rtp(false, { hevc(19), 0x00 }));
+        CHECK(!(o.signals & PEEK_SIG_FEC_CLOSE), "idr: no marker => no FEC_CLOSE");
+
+        // FU-A indirection: HEVC FU (type 49) carrying IDR(19) => PROTECT d1
+        // nal[0]=49<<1=0x62, nal[1]=layer/tid, nal[2]=S|type(19)=0x80|19
+        o = run(cfg, rtp(false, { 0x62, 0x01, (uint8_t)(0x80 | 19) }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "idr: FU-A IDR protect d1");
+    }
+
+    // ---- profile: refpred (HEVC) ----
+    {
+        peek_cfg_t cfg;
+        peek_cfg_set_profile(&cfg, "refpred");
+
+        auto o = run(cfg, rtp(false, { hevc(1), 0 }));       // TRAIL_R
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "refpred: TRAIL_R protect d1");
+
+        o = run(cfg, rtp(true, { hevc(0), 0 }));             // TRAIL_N + marker
+        CHECK(o.action == PEEK_ACT_DROP, "refpred: TRAIL_N drop");
+        CHECK(o.signals & PEEK_SIG_FEC_CLOSE,
+              "refpred: peek still reports FEC_CLOSE on dropped pkt (caller gates)");
+
+        o = run(cfg, rtp(false, { hevc(19), 0 }));           // IDR not handled here
+        CHECK(o.action == PEEK_ACT_PASS, "refpred: IDR pass (out of profile scope)");
+    }
+
+    // ---- profile: idr+refpred ----
+    {
+        peek_cfg_t cfg;
+        peek_cfg_set_profile(&cfg, "idr+refpred");
+
+        auto o = run(cfg, rtp(false, { hevc(33), 0 }));      // SPS
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 2, "idr+refpred: SPS d2");
+        o = run(cfg, rtp(false, { hevc(19), 0 }));           // IDR
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "idr+refpred: IDR d1");
+        o = run(cfg, rtp(false, { hevc(1), 0 }));            // TRAIL_R
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "idr+refpred: TRAIL_R d1");
+        o = run(cfg, rtp(false, { hevc(0), 0 }));            // TRAIL_N
+        CHECK(o.action == PEEK_ACT_DROP, "idr+refpred: TRAIL_N drop");
+    }
+
+    // ---- granular --peek-rule, H.264 ----
+    {
+        peek_cfg_t cfg;
+        peek_cfg_init(&cfg);
+        std::string err;
+        bool ok = peek_cfg_add_rule(&cfg, "h264:protect:idr:d1", &err);
+        CHECK(ok, "h264 rule parses");
+        if (!ok) printf("  err: %s\n", err.c_str());
+
+        // H.264 single-NAL IDR: nal[0]&0x1F=5 => 0x65
+        auto o = run(cfg, rtp(false, { 0x65, 0x00 }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "h264: IDR protect d1");
+
+        // H.264 FU-A (28) carrying IDR(5): nal[0]=0x7C, nal[1]=S|5=0x85
+        o = run(cfg, rtp(false, { 0x7C, 0x85 }));
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 1, "h264: FU-A IDR protect d1");
+
+        // non-IDR slice (type 1) => PASS
+        o = run(cfg, rtp(false, { 0x61, 0x00 }));
+        CHECK(o.action == PEEK_ACT_PASS, "h264: non-IDR pass");
+    }
+
+    // ---- fail-open / edge cases ----
+    {
+        peek_cfg_t cfg;
+        peek_cfg_set_profile(&cfg, "idr");
+
+        // too short to be RTP
+        std::vector<uint8_t> tiny = { 0x80, 0x60, 0x00 };
+        auto o = peek(tiny.data(), tiny.size(), &cfg);
+        CHECK(o.action == PEEK_ACT_PASS && o.signals == 0, "short datagram => PASS, no signals");
+
+        // RTP header present but no NAL bytes
+        o = run(cfg, rtp(true, {}));
+        CHECK(o.action == PEEK_ACT_PASS, "empty payload => PASS");
+        // marker still detected on a header-only datagram (byte 1 test)
+        CHECK(o.signals & PEEK_SIG_FEC_CLOSE, "empty payload marker => FEC_CLOSE");
+
+        // disabled cfg: no action, no signals, even with marker
+        peek_cfg_t off;
+        peek_cfg_set_profile(&off, "off");
+        o = run(off, rtp(true, { hevc(19), 0 }));
+        CHECK(o.action == PEEK_ACT_PASS && o.signals == 0, "off profile => zero-cost passthrough");
+    }
+
+    // ---- RTP with CSRC + extension: payload offset math ----
+    {
+        peek_cfg_t cfg;
+        peek_cfg_set_profile(&cfg, "idr");
+        // CC=1 (one CSRC, +4), X=1 (extension): byte0 = 0x80|0x10|0x01 = 0x91
+        std::vector<uint8_t> p;
+        p.push_back(0x91);
+        p.push_back(0x60);
+        for (int i = 0; i < 10; i++) p.push_back(0); // rest of fixed header
+        for (int i = 0; i < 4; i++) p.push_back(0);  // 1 CSRC
+        // extension header: 2 bytes profile + 2 bytes length(=1 word)
+        p.push_back(0); p.push_back(0); p.push_back(0x00); p.push_back(0x01);
+        for (int i = 0; i < 4; i++) p.push_back(0);  // 1 extension word
+        // now the NAL: VPS
+        p.push_back(hevc(32)); p.push_back(0x01);
+        auto o = peek(p.data(), p.size(), &cfg);
+        CHECK(o.action == PEEK_ACT_PROTECT && o.mcs_delta == 2,
+              "RTP CSRC+ext: payload located, VPS protect d2");
+    }
+
+    printf("\n%d/%d checks passed\n", g_total - g_fail, g_total);
+    return g_fail ? 1 : 0;
+}
