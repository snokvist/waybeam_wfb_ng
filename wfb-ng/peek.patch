+// --- peek (per-frame FEC close) ---
+//
+// One process-wide config; data_source reads it on every datagram and
+// CMD_SET_PEEK mutates the live enable toggle. Zero-initialised => enabled=false
+// => peek() is a no-op (zero-cost passthrough) until the profile/command arms
+// it. main() calls peek_cfg_init() so the mandatory FEC_CLOSE signal is seeded
+// even when armed later by command.
+static peek_cfg_t g_peek_cfg;
+
+// Run one datagram through peek and emit it. Shared by the SHM drain loop and
+// the UDP recvmsg path so both transports behave identically (and audio/uplink
+// instances, running with peek off, pay nothing). Always transmits; re-arms
+// fec_close_ts when a frame-boundary close fires.
+static inline bool peek_emit(Transmitter *t, const uint8_t *buf, size_t rsize,
+                             int fec_timeout, uint64_t &fec_close_ts,
+                             uint32_t &count_peek_closes)
+{
+    peek_outcome_t o = peek(buf, rsize, &g_peek_cfg);
+
+    t->send_packet(buf, rsize, 0);
+
+    if (o.signals & PEEK_SIG_FEC_CLOSE)
+    {
+        // Threshold-gate the per-frame block close.  Closing a near-empty block
+        // zero-pads it to k ON-AIR and emits full n-k parity (see send_packet
+        // FEC_ONLY path), so a P-frame-heavy 60/120fps stream would put ~fec_n
+        // packets on air per frame regardless of payload — overflowing the TX
+        // ring.  Only honor the close once the block holds a worthwhile fraction
+        // of k; smaller frames carry into the next block (it still auto-closes
+        // at k, and tiny-frame loss isolation is cheap).
+        int k = t->block_k();
+        if (k <= 0 || (int)t->block_fill() * 2 >= k)
+        {
+            // Enqueue order matters: the marked fragment is already in (above),
+            // so parity covers it.
+            while (t->send_packet(NULL, 0, WFB_PACKET_FEC_ONLY));
+            if (fec_timeout > 0) fec_close_ts = get_time_ms() + fec_timeout;
+            count_peek_closes += 1;
+        }
+    }
+    return true;
+}
