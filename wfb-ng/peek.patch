+/* peek {on|off|drop on|drop off|status}
+ *
+ * Two independent live toggles ride CMD_SET_PEEK; WFB_PEEK_KEEP leaves a
+ * toggle untouched.  status issues CMD_GET_PEEK and prints state + rule counts.
+ */
+int peek_cmd(char *progname, int port, int argc, char **argv)
+{
+    cmd_req_t req = { .req_id = htonl(rand()), .cmd_id = CMD_SET_PEEK };
+    cmd_resp_t resp;
+    int rc;
+
+    /* argv[0] == "peek"; sub-verb starts at argv[1] */
+    if (argc >= 2 && strcmp(argv[1], "status") == 0)
+    {
+        cmd_req_t greq = { .req_id = htonl(rand()), .cmd_id = CMD_GET_PEEK };
+        rc = send_command(port, greq, offsetof(cmd_req_t, u), &resp);
+        if (rc == 0)
+        {
+            printf("enabled=%d\n"
+                   "drop_enabled=%d\n"
+                   "n_rules=%d\n"
+                   "n_sig_rules=%d\n",
+                   resp.u.cmd_get_peek.enabled,
+                   resp.u.cmd_get_peek.drop_enabled,
+                   resp.u.cmd_get_peek.n_rules,
+                   resp.u.cmd_get_peek.n_sig_rules);
+        }
+        return rc;
+    }
+
+    req.u.cmd_set_peek.enabled      = WFB_PEEK_KEEP;
+    req.u.cmd_set_peek.drop_enabled = WFB_PEEK_KEEP;
+
+    if (argc >= 3 && strcmp(argv[1], "drop") == 0)
+    {
+        if      (strcmp(argv[2], "on")  == 0) req.u.cmd_set_peek.drop_enabled = 1;
+        else if (strcmp(argv[2], "off") == 0) req.u.cmd_set_peek.drop_enabled = 0;
+        else goto usage;
+    }
+    else if (argc >= 2 && strcmp(argv[1], "on") == 0)
+    {
+        req.u.cmd_set_peek.enabled = 1;
+    }
+    else if (argc >= 2 && strcmp(argv[1], "off") == 0)
+    {
+        req.u.cmd_set_peek.enabled = 0;
+    }
+    else
+    {
+    usage:
+        fprintf(stderr, "Usage: %s <port> peek {on | off | drop on | drop off | status}\n", progname);
+        return 1;
+    }
+
+    return send_command(port, req, offsetof(cmd_req_t, u) + sizeof(req.u.cmd_set_peek), &resp);
+}
+
