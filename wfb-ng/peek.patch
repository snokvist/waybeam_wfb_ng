@@ -0,0 +1,67 @@
+// -*- C++ -*-
+//
+// wfb_tx per-frame FEC close (peek).
+//
+// Self-contained, host-testable: peek() is a pure function over a datagram +
+// a config. The ONLY thing peek does is detect the RTP frame-boundary marker
+// (the M-bit at the end of each video frame) and signal a FEC block close, so
+// each frame's final block is closed on its own boundary (per-frame loss
+// isolation + tighter delivery timing). The transmit side (the threshold-gated
+// close) lives in tx.cpp.
+//
+// (The historical NAL-aware PROTECT/DROP action rules and the short-tail close
+// were removed — they perturbed the FEC/MCS control loop; only the
+// frame-boundary FEC close survives.)
+
+#ifndef WFB_PEEK_HPP
+#define WFB_PEEK_HPP
+
+#include <stdint.h>
+#include <stddef.h>
+
+// Byte-mask match, anchored at the datagram start (used for the RTP marker bit).
+typedef struct {
+    uint16_t off;
+    uint8_t  mask;
+    uint8_t  val;   // match iff (buf[off] & mask) == val
+} peek_match_t;
+
+// ---- control signals (accumulate all matches) ----
+typedef enum {
+    PEEK_SIG_FEC_CLOSE = 1u << 0, // close the FEC block at this packet
+} peek_signal_t;
+
+typedef struct {
+    peek_match_t match;
+    uint16_t     signal;          // bitmask of peek_signal_t
+} peek_sig_rule_t;
+
+#define PEEK_MAX_SIG_RULES  4
+
+typedef struct {
+    bool            enabled;       // master pipeline toggle (live)
+    peek_sig_rule_t sig_rules[PEEK_MAX_SIG_RULES]; // seeded with mandatory FEC_CLOSE
+    uint8_t         n_sig_rules;
+} peek_cfg_t;
+
+// Result of classifying one datagram.
+typedef struct {
+    uint16_t signals;  // bitmask of peek_signal_t
+} peek_outcome_t;
+
+// ---- public API ----
+
+// Zero a cfg and seed the mandatory frame-boundary FEC_CLOSE signal rule
+// (RTP marker bit). enabled is left false; the caller flips it via the startup
+// profile or CMD_SET_PEEK.
+void peek_cfg_init(peek_cfg_t *cfg);
+
+// Startup profile: "off" => disabled, "close" => enabled (frame-boundary FEC
+// close). Returns false on an unknown profile (cfg left as init).
+bool peek_cfg_set_profile(peek_cfg_t *cfg, const char *profile);
+
+// Classify one datagram. buf/len is the full datagram (RTP header included).
+// Fail-open: short/unparseable => no signals.
+peek_outcome_t peek(const uint8_t *buf, size_t len, const peek_cfg_t *cfg);
+
+#endif // WFB_PEEK_HPP
