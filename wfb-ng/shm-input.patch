 using namespace std;
 
+// --- UDP stats push (-Y host:port) ---
+//
+// Optional: emit one JSON datagram per -l log_interval to a fixed UDP
+// target. Mirror of the wfb_tx -Y mechanism (see SHM_HOWTO.md). Lets
+// external consumers (e.g. fec_controller, status WebUI, metrics
+// exporter) subscribe to per-antenna RSSI/SNR + aggregate counters
+// without attaching to wfb_rx's stdout. Replaces the
+// poc/ground_rssi_forwarder.py wrapper that used to bridge stdout
+// RX_ANT lines to UDP.
+//
+// Schema (single-line UTF-8 JSON, newline-terminated):
+//   {"ts_ms":..., "type":"rx_ant", "ver":1, "seq":..., "interval_ms":...,
+//    "ant":[{"freq":..., "mcs":..., "bw":..., "id":"<hex>",
+//            "pkts":..., "rssi":{"min":...,"avg":...,"max":...},
+//            "snr":{"min":...,"avg":...,"max":...}}, ...],
+//    "pkt":{"all":..., "bytes":..., "dec_err":..., "session":...,
+//           "data":..., "uniq":..., "fec_recovered":..., "lost":...,
+//           "bad":..., "outgoing":..., "outgoing_bytes":...,
+//           "diversity":...}}
+//
+// "diversity" is a multi-adapter overlap counter: increments when the same
+// data_nonce arrives on a second wlan_idx while count_p_uniq still holds it.
+// "fec_recovered" is parity-rebuild count from apply_fec(); the two are
+// independent (see Aggregator::process_packet for the increment sites).
+//
+// Best-effort: sendto() errors are silently ignored. Init failures
+// log once and leave the feature disabled — wfb_rx continues normally.
+static int g_stats_udp_fd = -1;
+static struct sockaddr_in g_stats_udp_dst;
+static bool g_stats_udp_enabled = false;
+static uint64_t g_stats_seq = 0;
+// Captured from main() so Aggregator::dump_stats() (no params) can
+// include the configured interval in the JSON without plumbing it
+// through the BaseAggregator interface.
+static int g_log_interval_ms = 1000;
+
+static void stats_udp_init(const char *target)
+{
+    if (!target || !*target) return;
+    const char *colon = strrchr(target, ':');
+    if (!colon || colon == target) {
+        fprintf(stderr, "stats: invalid -Y target '%s' (expected host:port)\n", target);
+        return;
+    }
+    char host[64];
+    size_t hlen = (size_t)(colon - target);
+    if (hlen >= sizeof(host)) {
+        fprintf(stderr, "stats: -Y host too long\n");
+        return;
+    }
+    memcpy(host, target, hlen);
+    host[hlen] = '\0';
+    int port = atoi(colon + 1);
+    if (port <= 0 || port > 65535) {
+        fprintf(stderr, "stats: invalid -Y port %d\n", port);
+        return;
+    }
+    int fd = socket(AF_INET, SOCK_DGRAM, 0);
+    if (fd < 0) {
+        fprintf(stderr, "stats: socket() failed: %s\n", strerror(errno));
+        return;
+    }
+    memset(&g_stats_udp_dst, 0, sizeof(g_stats_udp_dst));
+    g_stats_udp_dst.sin_family = AF_INET;
+    g_stats_udp_dst.sin_port   = htons((uint16_t)port);
+    if (inet_pton(AF_INET, host, &g_stats_udp_dst.sin_addr) != 1) {
+        fprintf(stderr, "stats: invalid -Y host '%s' (numeric IPv4 only)\n", host);
+        close(fd);
+        return;
+    }
+    g_stats_udp_fd = fd;
+    g_stats_udp_enabled = true;
+    fprintf(stderr, "stats: pushing rx_ant JSON to %s:%d every -l ms\n",
+            host, port);
+}
+
+// Quick check from Aggregator::dump_stats() so we can skip iterating
+// the antenna_stat map for serialization when no consumer is attached.
+static inline bool stats_udp_is_enabled(void)
+{
+    return g_stats_udp_enabled;
+}
+
+// Send a pre-formatted single datagram. Caller is responsible for size
+// and content; this is a thin wrapper to keep the sendto() boilerplate
+// in one place. Best-effort.
+static void stats_udp_send(const char *buf, size_t len)
+{
+    if (!g_stats_udp_enabled || len == 0) return;
+    (void)sendto(g_stats_udp_fd, buf, len, 0,
+                 (const struct sockaddr*)&g_stats_udp_dst,
+                 sizeof(g_stats_udp_dst));
+}
+// --- end stats push ---
