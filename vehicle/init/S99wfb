#!/bin/sh
# S99wfb - optional WFB-NG broadcaster mode for wlan0
# Enable:  fw_setenv wfbmode 1 ; reboot
# Disable: fw_setenv wfbmode 0 ; reboot
# Manual:  /etc/init.d/S99wfb {start|stop|restart|status}

# Shared helpers (PATH pin, log, mega detection, venc-shm wiring) — see
# init/wfb-common.sh. Fall back to inline definitions if the image predates it.
WFB_COMMON=/etc/wfb-common.sh
if [ -r "$WFB_COMMON" ]; then
    . "$WFB_COMMON"
else
    PATH=/usr/sbin:/usr/bin:/sbin:/bin; export PATH
    WFB_LOG_FILE="/tmp/wfb.log"
    log() { echo "[wfb] $*" | tee -a "$WFB_LOG_FILE"; }
    wfb_detect_mega() { command -v "wfb-$1" >/dev/null 2>&1 && WFB_MEGA="wfb-$1" || WFB_MEGA=""; }
    wfb_ensure_venc_shm() { :; }   # no shared fragment: assume encoder pre-wired
    wfb_seed_key() { [ -f "$2" ] || { [ -n "$WFB_MEGA" ] && "$WFB_MEGA" keygen-ensure --role "$1" "$2"; }; }
fi

# ── Operator settings ────────────────────────────────────────────────
# Everything else in this script is fixed wiring; live tuning happens
# via the link_controller HTTP API (port 8765, GET /schema).
WFB_CHANNEL=161
WFB_HTMODE=HT20
WFB_BW=20
WFB_TXPOWER=2000
KEY="/etc/drone.key"
# link_controller failsafe gating against rx_ant uplink burst loss.
# Default 0.5 s is too tight for a wfb-ng -k 1 -n 2 (50 % parity)
# rx_ant return path: occasional 0.5–2.0 s gaps from consecutive
# fragmented-frame loss trip the watchdog and force mcs_min even
# when the radio link itself is fine. 2.0 s absorbs typical bursts;
# raise WFB_FAILSAFE_S further if your uplink is lossier (or tighten
# the wfb-ng parity ratio of the uplink instead).
# See poc/CMD_PROXY.md → "Failsafe tuning".
WFB_FAILSAFE_S=2.0

# ── Fixed wiring — not tuning knobs ──────────────────────────────────
# Boot placeholders + topology. MCS/k/n below are only the static boot
# state of wfb_tx: link_controller rewrites all three within ~2 s of
# start (and the boot-armed failsafe drops MCS to mcs_min if no GS is
# heard), so there is nothing to tune here. Link ids/ports must match
# the GS supervisor config and link_controller defaults.
WFB_MCS=2
WFB_K=8
WFB_N=12
WFB_TX_LINK=207
WFB_RX_LINK=208
WFB_CTRL=8000
WFB_RX_FWD_PORT=5801
# Vehicle-side uplink rx_ant: the uplink wfb_rx pushes its OWN reception stats
# (GS->vehicle RSSI, how the vehicle hears the GS) here via -Y. link_controller
# ingests it on a separate, diagnostic-only listener (never feeds MCS/FEC) and
# surfaces it under "uplink_rx" in /status. This is genuinely independent
# antenna data from the GS-relayed downlink rx_ant on WFB_RX_FWD_PORT, and
# proves WCMD/CSA actionable data actually reaches the vehicle.
WFB_UPLINK_RX_PORT=5811
SAFE_BITRATE=4096
SHM_RING="local_shm"

# ── Script-controlled policy (NOT environment variables) ─────────────
# wfbmode is the ONLY boot-env knob (fw_setenv wfbmode 0|1). Everything
# below is fixed policy for this build — edit it here and redeploy the
# script; there are no fw_setenv overrides for these.
WFB_PEEK_PROFILE=close   # per-frame FEC close: off | close (gate close only)
WFB_PROBE=               # V+2 boundary probe: default ON; set WFB_PROBE=0 to disable
WFB_LOG=1                # in-process SD telemetry logger: 1=on

# V+2 boundary-probe producer: one extra wfb_tx at V+2, fed and retuned
# by link_controller. Default ON (enabled unless WFB_PROBE=0) — it is REQUIRED
# for MCS adaptation (the unified PER-probe law promotes on probe data only).
# Leaving WFB_PROBE empty/unset keeps it on; only an explicit WFB_PROBE=0 opts
# out, which starts link_controller with --no-mcs (FEC-only; MCS stays at the
# static WFB_MCS set on wfb_tx above).
# Probe stream mirrors the video PHY (-B/-S/-L), FEC 1/1, AEAD off (-x),
# on its own link_id so it can never collide with video (207) / uplink (208).
# See telemetry/PROBE_PER_SPEC.md.
WFB_PROBE_LINK=50
WFB_PROBE_PORT=50
WFB_PROBE_CTRL=8001
WFB_PROBE_FEED=5750

PID_TX="/var/run/wfb_tx.pid"
PID_RX="/var/run/wfb_rx.pid"
PID_LC="/var/run/link_controller.pid"
PID_PTX="/var/run/wfb_probe_tx.pid"
LOG="/tmp/wfb.log"
# SD telemetry logging is now IN-PROCESS in link_controller (it replaced the
# separate walkout_logger.sh): per-boot sessions under /mnt/mmcblk0p1/walkout/,
# 1 Hz status.jsonl + an lc.log decision mirror, newest 10 kept, inactive when
# no SD is mounted (logs never land on the overlay). The GS "New capture"
# button can also roll a fresh, time-aligned session via WCMD_KEY_LOG_CONTROL.
# Default ON; disable entirely by setting WFB_LOG=0 (script constant above,
# passes --no-log).

# ── Mega binary (single wfb-air) support ─────────────────────────────
# If the multi-call wfb-air binary is installed, route the applets through
# it (busybox-style); otherwise fall back to the standalone binaries. The
# rest of this script is unchanged — only the launch tokens and the
# pidof/killall process-name list differ. See docs/design/mega-binary.md.
wfb_detect_mega air
if [ -n "$WFB_MEGA" ]; then
    WFB_TX="$WFB_MEGA tx"
    WFB_RX="$WFB_MEGA rx"
    LINK_CONTROLLER="$WFB_MEGA link"
    WFB_PROCS="$WFB_MEGA"          # all applets share this comm name
else
    WFB_TX="wfb_tx"
    WFB_RX="wfb_rx"
    LINK_CONTROLLER="link_controller"
    WFB_PROCS="link_controller wfb_rx wfb_tx"
fi

fw_get() { fw_printenv -n "$1" 2>/dev/null || echo "$2"; }
is_enabled() { [ "$(fw_get wfbmode 0)" = "1" ]; }
probe_enabled() { [ "$WFB_PROBE" != "0" ]; }   # default ON; only WFB_PROBE=0 disables
# True if any tracked applet (by pidfile) is still alive. Precise on purpose:
# in mega mode all applets share comm 'wfb-air', so `pidof wfb-air` can't tell
# our daemons from an unrelated/manual wfb-air invocation (e.g. a debug
# tx_cmd/keygen) — which would make the double-start guard over-reach.
wfb_running() {
    for f in "$PID_LC" "$PID_TX" "$PID_RX" "$PID_PTX"; do
        [ -f "$f" ] && kill -0 "$(cat "$f")" 2>/dev/null && return 0
    done
    return 1
}
# log() is provided by wfb-common.sh (writes to $WFB_LOG_FILE == $LOG).

start_wfb() {
    log "starting WFB-NG broadcaster"

    # Guard against double-start. A bare repeated `start` (boot + a manual
    # start, or a deploy that skipped `stop`) would otherwise STACK a second
    # link_controller on top of the running one — two controllers then fight
    # over the wfb_tx control socket (-C) and the venc HTTP API, which surfaces
    # as link / MCS flapping. If anything from a prior run is still alive, clear
    # it first so `start` is idempotent (behaves like `restart`).
    if wfb_running; then
        log "start: existing wfb instance detected — clearing it first (no double-start)"
        stop_wfb
        sleep 0.5
    fi

    # First-boot key: seed a shared bring-up drone.key from the built-in
    # "Waybeam" passphrase if none exists, so an unconfigured pair still links
    # (INSECURE shared default — replace for production). No-op if $KEY exists.
    wfb_seed_key drone "$KEY"

    # Tear down AP (kills hostapd + adapter monitor + flushes wlan0)
    /usr/bin/adapter stop >> "$LOG" 2>&1
    sleep 0.5

    # Monitor mode + channel + txpower
    iw dev wlan0 set monitor otherbss >> "$LOG" 2>&1
    ip link set wlan0 up
    iw dev wlan0 set channel $WFB_CHANNEL $WFB_HTMODE >> "$LOG" 2>&1
    iw dev wlan0 set txpower fixed $WFB_TXPOWER >> "$LOG" 2>&1

    # Make the encoder publish into the SHM ring our video wfb_tx reads from.
    # Only rewires + SIGHUPs the encoder if it isn't already on shm://$SHM_RING
    # (so a correctly-configured, fragile SoC encoder is never reinited for
    # nothing). See wfb_ensure_venc_shm in wfb-common.sh.
    wfb_ensure_venc_shm "$SHM_RING"

    # Peek = per-frame FEC close. --peek-profile selects the startup state; the
    # WCMD/WebUI peek toggle arms/disarms it live.
    #   close (default) — armed: close each video frame's FEC block at the RTP
    #     marker for per-frame loss isolation + tighter RTP timing.
    #   off — peek disabled (no per-frame close).
    # The old NAL-aware PROTECT/DROP profiles (idr/refpred) and the short-tail
    # close were removed — both flapped the MCS loop; only the gate close ships.
    # Profile is the WFB_PEEK_PROFILE script constant at the top (not an env var).

    # wfb_tx (SHM input from venc).  -T sizes the FEC safety-net timeout
    # to the typical frame period (60 fps ≈ 16 ms); fec_controller can
    # rewrite this at runtime via CMD_SET_FEC's fec_timeout_ms field.
    $WFB_TX -K "$KEY" -M $WFB_MCS -B $WFB_BW -k $WFB_K -n $WFB_N \
           -P 1 -Q -S 1 -L 1 -C $WFB_CTRL -T 16 \
           -H "$SHM_RING" -R 2097152 -s 2097152 \
           --peek-profile "$WFB_PEEK_PROFILE" \
           -l 1000 -i $WFB_TX_LINK -p 0 -x wlan0 \
           >> "$LOG" 2>&1 &
    echo $! > "$PID_TX"
    log "video wfb_tx up (peek-profile=$WFB_PEEK_PROFILE)"

    # wfb_rx (uplink data forwarder - decoded packets to 127.0.0.1:5801).
    # -Y pushes this RX's own rx_ant stats (the GS->vehicle uplink as the
    # vehicle hears it) to link_controller's diagnostic uplink listener.
    $WFB_RX -K "$KEY" -i $WFB_RX_LINK -u $WFB_RX_FWD_PORT -p 0 \
           -Y 127.0.0.1:$WFB_UPLINK_RX_PORT wlan0 \
           >> "$LOG" 2>&1 &
    echo $! > "$PID_RX"

    # Probe wfb_tx (V+2 producer; WFB_PROBE=1). Spawned at a best-effort
    # V+2 MCS; link_controller retunes it on its control socket (-C) and
    # feeds paced PRB packets to its udp input (-u). FEC 1/1 so raw loss
    # is not masked; -x because the GS probe rx runs -x (PER measurement
    # does not need AEAD). WFB_PROBE=0 -> no probe -> MCS adaptation off
    # (--no-mcs), since the unified law cannot promote without it; the
    # CSA receiver goes with it (it reuses the MCS rx_ant listener).
    PROBE_ARGS="--no-mcs"
    if probe_enabled; then
        PROBE_MCS=$((WFB_MCS + 2))
        [ "$PROBE_MCS" -gt 7 ] && PROBE_MCS=7
        $WFB_TX -K "$KEY" -i $WFB_PROBE_LINK -p $WFB_PROBE_PORT \
               -M $PROBE_MCS -B $WFB_BW -S 1 -L 1 -k 1 -n 1 \
               -C $WFB_PROBE_CTRL -u $WFB_PROBE_FEED \
               -l 1000 -x wlan0 \
               >> "$LOG" 2>&1 &
        echo $! > "$PID_PTX"
        PROBE_ARGS="--csa-iface wlan0 --probe 127.0.0.1:$WFB_PROBE_CTRL --probe-feed 127.0.0.1:$WFB_PROBE_FEED"
        log "probe wfb_tx up (link=$WFB_PROBE_LINK port=$WFB_PROBE_PORT mcs=$PROBE_MCS ctrl=$WFB_PROBE_CTRL feed=$WFB_PROBE_FEED)"
    fi

    # link_controller (writes safe bitrate to venc on startup, adaptive FEC,
    # WebUI on :8765 reachable via eth0). --stats binds the rx_ant socket
    # for both MCS scoring and the venc command proxy (CMD_PROXY.md).
    # --failsafe absorbs bursty rx_ant loss over the wfb-ng uplink — see
    # WFB_FAILSAFE_S above.
    # $PROBE_ARGS is intentionally unquoted (--csa-iface + --probe +
    # --probe-feed when WFB_PROBE=1, --no-mcs otherwise — CSA rides the
    # MCS rx_ant listener so it is gated together with the probe).
    # $LOG_ARGS gates the in-process SD telemetry logger (default on; --no-log
    # when WFB_LOG=0). It logs to /mnt/mmcblk0p1 and self-disables if absent.
    LOG_ARGS=""
    [ "$WFB_LOG" = "1" ] || LOG_ARGS="--no-log"
    $LINK_CONTROLLER \
        --wfb 127.0.0.1:$WFB_CTRL \
        --venc 127.0.0.1:80 \
        --safe-startup-bitrate $SAFE_BITRATE \
        --stats 0.0.0.0:$WFB_RX_FWD_PORT \
        --uplink-stats $WFB_UPLINK_RX_PORT \
        --failsafe $WFB_FAILSAFE_S \
        --wfb-iface wlan0 \
        $PROBE_ARGS $LOG_ARGS \
        >> "$LOG" 2>&1 &
    echo $! > "$PID_LC"

    log "started (tx=$(cat $PID_TX) rx=$(cat $PID_RX) lc=$(cat $PID_LC)$(probe_enabled && echo " ptx=$(cat $PID_PTX)"))"
}

stop_wfb() {
    log "stopping"
    for f in "$PID_LC" "$PID_PTX" "$PID_RX" "$PID_TX"; do
        [ -f "$f" ] && { kill "$(cat $f)" 2>/dev/null; rm -f "$f"; }
    done
    sleep 0.5
    killall -q $WFB_PROCS 2>/dev/null
    # Legacy cleanup: pre-#70 images spawned a separate walkout_logger.sh (SD
    # logging is in-process in link_controller now). Reap any survivor so it
    # can't linger as an orphan across a stop/start.
    killall -q walkout_logger.sh 2>/dev/null
    rm -f /var/run/walkout_logger.pid 2>/dev/null
    sleep 0.3
    ip link set wlan0 down 2>/dev/null
    # Return wlan0 to AP mode (or whatever wlanmode is set to)
    /usr/bin/adapter start >> "$LOG" 2>&1
    log "wlan0 restored via adapter"
}

status_wfb() {
    echo "wfbmode env: $(fw_get wfbmode 0)  probe: $(probe_enabled && echo on || echo off)  peek: $WFB_PEEK_PROFILE  (script-fixed)"
    if command -v wfb-air >/dev/null 2>&1; then
        # All applets share comm 'wfb-air'; report per-role from the pid files
        # so a single dead applet is still visible (pidof wfb-air can't tell
        # them apart).
        echo "  (mega: applets share comm 'wfb-air' — per-role from pidfiles)"
        for rolepid in "video-tx:$PID_TX" "uplink-rx:$PID_RX" "link:$PID_LC" "probe-tx:$PID_PTX"; do
            role=${rolepid%%:*}; f=${rolepid#*:}
            if [ -f "$f" ] && kill -0 "$(cat "$f")" 2>/dev/null; then
                echo "  $role (wfb-air): $(cat "$f")"
            else
                echo "  $role (wfb-air): not running"
            fi
        done
    else
        for name in wfb_tx wfb_rx link_controller; do
            pid=$(pidof "$name" 2>/dev/null)
            echo "  $name: ${pid:-not running}"
        done
        if [ -f "$PID_PTX" ]; then
            ppid=$(cat "$PID_PTX")
            kill -0 "$ppid" 2>/dev/null \
                && echo "  probe wfb_tx: $ppid" \
                || echo "  probe wfb_tx: stale pidfile ($ppid)"
        fi
    fi
    echo "  sd logger: in-process in link_controller (log: $WFB_LOG (script), SD: $(grep -q ' /mnt/mmcblk0p1 ' /proc/mounts && echo present || echo absent), latest: $(ls -1d /mnt/mmcblk0p1/walkout/*/ 2>/dev/null | sort | tail -1 || echo none))"
    [ "$(fw_get wfbmode 0)" = "1" ] && command -v curl >/dev/null 2>&1 && \
        echo "  sd logger live: $(curl -s -m 2 http://127.0.0.1:8765/log/status 2>/dev/null || echo '(link_controller /log/status unreachable)')"
    echo "wlan0:"
    iw dev wlan0 info 2>/dev/null | grep -E "type|channel|txpower" | sed 's/^/  /'
}

case "$1" in
    start)
        if is_enabled; then
            start_wfb
        else
            log "disabled (fw_setenv wfbmode 1 to enable)"
        fi
        ;;
    stop)    stop_wfb ;;
    restart) stop_wfb; sleep 0.5; start_wfb ;;
    status)  status_wfb ;;
    *)       echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
exit 0
