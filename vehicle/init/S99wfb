#!/bin/sh
# S99wfb - optional WFB-NG broadcaster mode (radio.iface, default wlan0)
# Enable:  fw_setenv wfbmode 1 ; reboot
# Disable: fw_setenv wfbmode 0 ; reboot
# Manual:  /etc/init.d/S99wfb {start|stop|restart|status}

# Shared helpers (PATH pin, log, mega detection, venc-shm wiring) — see
# init/wfb-common.sh. Fall back to inline definitions if the image predates it.
WFB_COMMON=/etc/wfb-common.sh
if [ -r "$WFB_COMMON" ]; then
    . "$WFB_COMMON"
else
    PATH=/usr/sbin:/usr/bin:/sbin:/bin; export PATH
    WFB_LOG_FILE="/tmp/wfb.log"
    log() { echo "[wfb] $*" | tee -a "$WFB_LOG_FILE"; }
    wfb_detect_mega() { command -v "wfb-$1" >/dev/null 2>&1 && WFB_MEGA="wfb-$1" || WFB_MEGA=""; }
    wfb_ensure_venc_shm() { :; }   # no shared fragment: assume encoder pre-wired
    wfb_seed_key() { [ -f "$2" ] || { [ -n "$WFB_MEGA" ] && "$WFB_MEGA" keygen-ensure --role "$1" ${3:+--seed "$3"} "$2"; }; }
fi

# ── Configuration ────────────────────────────────────────────────────
# Every operator setting lives in /etc/wfb-link.json, rendered to shell by
# the mega binary's `config-env` applet. The defaults are authoritative in
# multicall/wfb_configenv.c — there is NO second copy of them here. A
# missing/empty/invalid file yields exactly the shipped preset, so the link
# comes up unchanged. The ONLY boot-env knob is `fw_setenv wfbmode 0|1`;
# live tuning of the adaptive loop is via the link_controller HTTP API
# (:8765, GET /schema). Knobs rendered (see wfb_configenv.c for defaults):
#   radio:    WFB_CHANNEL WFB_HTMODE WFB_BW WFB_TXPOWER WFB_IFACE
#   key:      KEY WFB_KEY_SEED WFB_VIDEO_OPEN
#   links:    WFB_TX_LINK WFB_RX_LINK WFB_PROBE_LINK WFB_PROBE_PORT
#   fec/mcs:  WFB_K WFB_N WFB_MCS WFB_MCS_MIN WFB_MCS_MAX WFB_BITRATE_MIN
#   policy:   WFB_PROBE WFB_PEEK_PROFILE WFB_LOG
#   venc:     SHM_RING WFB_VENC_AUTOWIRE WFB_VENC_HOST SAFE_BITRATE
#   failsafe: WFB_FAILSAFE_S   (link_controller uplink-loss watchdog, seconds)
#   ports:    WFB_CTRL WFB_RX_FWD_PORT WFB_UPLINK_RX_PORT
#             WFB_PROBE_CTRL WFB_PROBE_FEED
# WFB_PROBE is the V+2 boundary probe (default ON; required for MCS
# adaptation — 0 starts link_controller with --no-mcs). Link ids, fec/mcs,
# bw/htmode and peek must match the GS supervisor config on both ends.

PID_TX="/var/run/wfb_tx.pid"
PID_RX="/var/run/wfb_rx.pid"
PID_LC="/var/run/link_controller.pid"
PID_PTX="/var/run/wfb_probe_tx.pid"
PID_RXR="/var/run/wfb_rx_recovery.pid"
LOG="/tmp/wfb.log"
# SD telemetry logging is now IN-PROCESS in link_controller (it replaced the
# separate walkout_logger.sh): per-boot sessions under /mnt/mmcblk0p1/walkout/,
# 1 Hz status.jsonl + an lc.log decision mirror, newest 10 kept, inactive when
# no SD is mounted (logs never land on the overlay). The GS "New capture"
# button can also roll a fresh, time-aligned session via WCMD_KEY_LOG_CONTROL.
# Default ON; disable via `log.enabled: false` in /etc/wfb-link.json
# (WFB_LOG=0 -> link_controller --no-log).

# ── Mega binary (single wfb-air) support ─────────────────────────────
# If the multi-call wfb-air binary is installed, route the applets through
# it (busybox-style); otherwise fall back to the standalone binaries. The
# rest of this script is unchanged — only the launch tokens and the
# pidof/killall process-name list differ. See docs/design/mega-binary.md.
wfb_detect_mega air
if [ -n "$WFB_MEGA" ]; then
    WFB_TX="$WFB_MEGA tx"
    WFB_RX="$WFB_MEGA rx"
    LINK_CONTROLLER="$WFB_MEGA link"
    WFB_PROCS="$WFB_MEGA"          # all applets share this comm name
else
    WFB_TX="wfb_tx"
    WFB_RX="wfb_rx"
    LINK_CONTROLLER="link_controller"
    WFB_PROCS="link_controller wfb_rx wfb_tx"
fi

# Render the unified link preset (/etc/wfb-link.json) into this shell. The
# config-env applet bakes every default, so a missing/empty/invalid file
# yields the shipped preset and the link comes up unchanged. This is the
# single source of truth for the mega deployment — no constants above.
WFB_LINK_CONF="${WFB_LINK_CONF:-/etc/wfb-link.json}"
if [ -n "$WFB_MEGA" ]; then
    eval "$("$WFB_MEGA" config-env "$WFB_LINK_CONF" 2>>"$LOG")"
else
    # Standalone fallback (no mega binary => no config-env applet). These
    # MUST mirror the defaults in multicall/wfb_configenv.c, which stays
    # authoritative. Standalone is a legacy path — prefer the mega binary.
    : "${WFB_CHANNEL:=161}"  "${WFB_HTMODE:=HT20}"  "${WFB_BW:=20}"  "${WFB_TXPOWER:=2000}"  "${WFB_IFACE:=wlan0}"  "${WFB_MTU:=4052}"
    : "${KEY:=/etc/drone.key}"  "${WFB_KEY_SEED:=Waybeam}"
    : "${WFB_TX_LINK:=207}"  "${WFB_RX_LINK:=208}"  "${WFB_PROBE_LINK:=50}"  "${WFB_PROBE_PORT:=50}"
    : "${WFB_K:=8}"  "${WFB_N:=12}"  "${WFB_MCS:=2}"  "${WFB_MCS_MIN:=1}"  "${WFB_MCS_MAX:=7}"
    : "${WFB_PAYLOAD_MAX:=0}"  "${WFB_PAYLOAD_MIN:=576}"
    : "${WFB_AIRTIME_MAX_PCT:=80}"  "${WFB_AIRTIME_PREAMBLE_US:=40}"
    : "${WFB_BITRATE_MIN:=2200}"
    : "${WFB_PROBE:=1}"  "${WFB_PEEK_PROFILE:=close}"  "${WFB_LOG:=1}"  "${WFB_VIDEO_OPEN:=1}"
    : "${SHM_RING:=local_shm}"  "${WFB_VENC_AUTOWIRE:=1}"  "${WFB_VENC_HOST:=127.0.0.1:80}"
    : "${SAFE_BITRATE:=4096}"  "${WFB_FAILSAFE_S:=2.0}"
    : "${WFB_CTRL:=8000}"  "${WFB_RX_FWD_PORT:=5801}"  "${WFB_UPLINK_RX_PORT:=5811}"
    : "${WFB_PROBE_CTRL:=8001}"  "${WFB_PROBE_FEED:=5750}"
    : "${WFB_RECOVERY:=1}"  "${WFB_RECOVERY_LINK:=209}"  "${WFB_RECOVERY_PORT:=5802}"
    : "${WFB_RECOVERY_CMD:=/etc/wfb/recovery-apfpv.sh}"
fi

fw_get() { fw_printenv -n "$1" 2>/dev/null || echo "$2"; }
is_enabled() { [ "$(fw_get wfbmode 0)" = "1" ]; }
probe_enabled() { [ "$WFB_PROBE" != "0" ]; }   # default ON; only WFB_PROBE=0 disables
# True if any tracked applet (by pidfile) is still alive. Precise on purpose:
# in mega mode all applets share comm 'wfb-air', so `pidof wfb-air` can't tell
# our daemons from an unrelated/manual wfb-air invocation (e.g. a debug
# tx_cmd/keygen) — which would make the double-start guard over-reach.
wfb_running() {
    for f in "$PID_LC" "$PID_TX" "$PID_RX" "$PID_PTX" "$PID_RXR"; do
        [ -f "$f" ] && kill -0 "$(cat "$f")" 2>/dev/null && return 0
    done
    return 1
}
# log() is provided by wfb-common.sh (writes to $WFB_LOG_FILE == $LOG).

start_wfb() {
    log "starting WFB-NG broadcaster"

    # Guard against double-start. A bare repeated `start` (boot + a manual
    # start, or a deploy that skipped `stop`) would otherwise STACK a second
    # link_controller on top of the running one — two controllers then fight
    # over the wfb_tx control socket (-C) and the venc HTTP API, which surfaces
    # as link / MCS flapping. If anything from a prior run is still alive, clear
    # it first so `start` is idempotent (behaves like `restart`).
    if wfb_running; then
        log "start: existing wfb instance detected — clearing it first (no double-start)"
        stop_wfb
        sleep 0.5
    fi

    # First-boot key: seed a shared bring-up drone.key from the built-in
    # "Waybeam" passphrase if none exists, so an unconfigured pair still links
    # (INSECURE shared default — replace for production). No-op if $KEY exists.
    wfb_seed_key drone "$KEY" "$WFB_KEY_SEED"

    # Tear down AP (kills hostapd + adapter monitor + flushes the iface).
    # adapter honors $IFACE (defaults to wlan0) — pass WFB_IFACE through.
    IFACE="$WFB_IFACE" /usr/bin/adapter stop >> "$LOG" 2>&1
    sleep 0.5

    # Monitor mode + channel + txpower
    iw dev "$WFB_IFACE" set monitor otherbss >> "$LOG" 2>&1
    ip link set "$WFB_IFACE" up
    iw dev "$WFB_IFACE" set channel $WFB_CHANNEL $WFB_HTMODE >> "$LOG" 2>&1
    iw dev "$WFB_IFACE" set txpower fixed $WFB_TXPOWER >> "$LOG" 2>&1

    # Raise the monitor-iface MTU. The default 1500 caps wfb_tx injection
    # frames, so any RTP payload above ~1500 (adaptive payload sizing,
    # fec.payload_max) overflows the link MTU and wedges the TX path (ring
    # backpressure -> MCS0 failsafe). Set it AFTER monitor mode is established
    # (the iw/ip steps above can reset it) and BEFORE wfb_tx starts. WFB_MTU
    # comes from wfb-link.json radio.mtu (config-env), default 4052 =
    # WLAN_DATA_MAXLEN, the rtl88x2eu driver's hard max (include/wifi.h; the
    # driver's TX buffers are sized for it and this old kernel does NOT enforce
    # max_mtu, so we must cap here). The adaptive sizer never selects above the
    # 3200 tier ceiling, so 4052 leaves comfortable framing headroom. Clamp to
    # [1500,4052] so a bad value can't brick start or exceed the driver max.
    case "$WFB_MTU" in ''|*[!0-9]*) WFB_MTU=4052 ;; esac
    [ "$WFB_MTU" -ge 1500 ] && [ "$WFB_MTU" -le 4052 ] || WFB_MTU=4052
    if ip link set dev "$WFB_IFACE" mtu "$WFB_MTU" >> "$LOG" 2>&1; then
        log "$WFB_IFACE mtu set to $WFB_MTU"
    else
        log "WARN: failed to set $WFB_IFACE mtu=$WFB_MTU (payloads >1500 may wedge)"
    fi

    # Make the encoder publish into the SHM ring our video wfb_tx reads from.
    # Only rewires + SIGHUPs the encoder if it isn't already on shm://$SHM_RING
    # (so a correctly-configured, fragile SoC encoder is never reinited for
    # nothing). See wfb_ensure_venc_shm in wfb-common.sh. Gated by
    # venc.auto_wire (WFB_VENC_AUTOWIRE; default on) from /etc/wfb-link.json.
    [ "${WFB_VENC_AUTOWIRE:-1}" != "0" ] && wfb_ensure_venc_shm "$SHM_RING"

    # Peek = per-frame FEC close. --peek-profile selects the startup state; the
    # WCMD/WebUI peek toggle arms/disarms it live.
    #   close (default) — armed: close each video frame's FEC block at the RTP
    #     marker for per-frame loss isolation + tighter RTP timing.
    #   off — peek disabled (no per-frame close).
    # The old NAL-aware PROTECT/DROP profiles (idr/refpred) and the short-tail
    # close were removed — both flapped the MCS loop; only the gate close ships.
    # Profile is WFB_PEEK_PROFILE from /etc/wfb-link.json (peek.profile).

    # wfb_tx (SHM input from venc).  -T sizes the FEC safety-net timeout
    # to the typical frame period (60 fps ≈ 16 ms); fec_controller can
    # rewrite this at runtime via CMD_SET_FEC's fec_timeout_ms field.
    #
    # Video session crypto is config-driven via WFB_VIDEO_OPEN (wfb-link.json
    # key.open, default 1):
    #   1 -> -xx OPEN VIDEO: plaintext data + cleartext, keyless session announce
    #        (WFB_PACKET_SESSION_PLAIN). No keypair needed; viewable by any wfb_rx
    #        running -x, including receivers that hold no key. -K is still passed
    #        (harmless; the ctor ignores the key in -xx mode) so the same KEY
    #        drives the encrypted uplink rx below.
    #   0 -> -x  authenticated session: data plaintext but the session announce
    #        is crypto_box-signed; the RX needs the matching keypair.
    # (Drop to no -x for full per-fragment AEAD; not exposed as a knob here.)
    if [ "${WFB_VIDEO_OPEN:-1}" = "1" ]; then WFB_VIDEO_SESS="-xx"; else WFB_VIDEO_SESS="-x"; fi
    $WFB_TX -K "$KEY" -M $WFB_MCS -B $WFB_BW -k $WFB_K -n $WFB_N \
           -P 1 -Q -S 1 -L 1 -C $WFB_CTRL -T 16 \
           -H "$SHM_RING" -R 2097152 -s 2097152 \
           --peek-profile "$WFB_PEEK_PROFILE" \
           -l 1000 -i $WFB_TX_LINK -p 0 $WFB_VIDEO_SESS "$WFB_IFACE" \
           >> "$LOG" 2>&1 &
    echo $! > "$PID_TX"
    log "video wfb_tx up (peek-profile=$WFB_PEEK_PROFILE session=$WFB_VIDEO_SESS)"

    # wfb_rx (uplink data forwarder - decoded packets to 127.0.0.1:5801).
    # -Y pushes this RX's own rx_ant stats (the GS->vehicle uplink as the
    # vehicle hears it) to link_controller's diagnostic uplink listener.
    $WFB_RX -K "$KEY" -i $WFB_RX_LINK -u $WFB_RX_FWD_PORT -p 0 \
           -Y 127.0.0.1:$WFB_UPLINK_RX_PORT "$WFB_IFACE" \
           >> "$LOG" 2>&1 &
    echo $! > "$PID_RX"

    # Recovery backdoor wfb_rx (WFB_RECOVERY=1). KEYLESS by design: no -K, -x
    # only, so it decodes the GS's open (-xx) recovery TX even when the keyed
    # uplink is dead (wrong/lost drone.key). Forwards decoded frames to the
    # link_controller recovery listener (127.0.0.1:$WFB_RECOVERY_PORT), where
    # recovery_dispatch() accepts ONLY the single APFPV-recovery key. Separate
    # link id ($WFB_RECOVERY_LINK) keeps it off the keyed uplink entirely.
    RECOVERY_ARGS=""
    if [ "$WFB_RECOVERY" = "1" ]; then
        $WFB_RX -i $WFB_RECOVERY_LINK -u $WFB_RECOVERY_PORT -p 0 \
               -x "$WFB_IFACE" \
               >> "$LOG" 2>&1 &
        echo $! > "$PID_RXR"
        RECOVERY_ARGS="--recovery-port $WFB_RECOVERY_PORT --recovery-cmd $WFB_RECOVERY_CMD"
        log "recovery rx up (keyless -x, link=$WFB_RECOVERY_LINK -> :$WFB_RECOVERY_PORT, hook=$WFB_RECOVERY_CMD)"
    else
        RECOVERY_ARGS="--no-recovery"
    fi

    # Probe wfb_tx (V+2 producer; WFB_PROBE=1). Spawned at a best-effort
    # V+2 MCS; link_controller retunes it on its control socket (-C) and
    # feeds paced PRB packets to its udp input (-u). FEC 1/1 so raw loss
    # is not masked; -x because the GS probe rx runs -x (PER measurement
    # does not need AEAD). WFB_PROBE=0 -> no probe -> MCS adaptation off
    # (--no-mcs), since the unified law cannot promote without it; the
    # CSA receiver goes with it (it reuses the MCS rx_ant listener).
    PROBE_ARGS="--no-mcs"
    if probe_enabled; then
        PROBE_MCS=$((WFB_MCS + 2))
        [ "$PROBE_MCS" -gt 7 ] && PROBE_MCS=7
        $WFB_TX -K "$KEY" -i $WFB_PROBE_LINK -p $WFB_PROBE_PORT \
               -M $PROBE_MCS -B $WFB_BW -S 1 -L 1 -k 1 -n 1 \
               -C $WFB_PROBE_CTRL -u $WFB_PROBE_FEED \
               -l 1000 -x "$WFB_IFACE" \
               >> "$LOG" 2>&1 &
        echo $! > "$PID_PTX"
        PROBE_ARGS="--csa-iface $WFB_IFACE --probe 127.0.0.1:$WFB_PROBE_CTRL --probe-feed 127.0.0.1:$WFB_PROBE_FEED"
        log "probe wfb_tx up (link=$WFB_PROBE_LINK port=$WFB_PROBE_PORT mcs=$PROBE_MCS ctrl=$WFB_PROBE_CTRL feed=$WFB_PROBE_FEED)"
    fi

    # link_controller (writes safe bitrate to venc on startup, adaptive FEC,
    # WebUI on :8765 reachable via eth0). --stats binds the rx_ant socket
    # for both MCS scoring and the venc command proxy (CMD_PROXY.md).
    # --failsafe absorbs bursty rx_ant loss over the wfb-ng uplink — see
    # WFB_FAILSAFE_S above.
    # $PROBE_ARGS is intentionally unquoted (--csa-iface + --probe +
    # --probe-feed when WFB_PROBE=1, --no-mcs otherwise — CSA rides the
    # MCS rx_ant listener so it is gated together with the probe).
    # $LOG_ARGS gates the in-process SD telemetry logger (default on; --no-log
    # when WFB_LOG=0). It logs to /mnt/mmcblk0p1 and self-disables if absent.
    LOG_ARGS=""
    [ "$WFB_LOG" = "1" ] || LOG_ARGS="--no-log"
    # Adaptive RTP payload sizing (fec.payload_max in wfb-link.json; 0 = off).
    # Persists the operator's path-MTU ceiling across reboots; the controller
    # then sizes venc outgoing.maxPayloadSize by bitrate tier. Also live-tunable
    # via the link_controller /set API (fec.payload_max / fec.payload_min).
    # The daemon rejects an out-of-range --max-payload with exit 1, so a bad
    # wfb-link.json value must NOT reach the CLI or it would brick the boot
    # link. Validate here at the config->CLI boundary: anything not 0 and not a
    # clean [576,4000] integer degrades to "sizing off" with a log line.
    PAYLOAD_ARGS=""
    case "$WFB_PAYLOAD_MAX" in
        0) ;;                                   # feature off
        ''|*[!0-9]*)
            log "WFB_PAYLOAD_MAX='$WFB_PAYLOAD_MAX' not numeric; payload sizing off" ;;
        *)
            if [ "$WFB_PAYLOAD_MAX" -ge 576 ] && [ "$WFB_PAYLOAD_MAX" -le 4000 ]; then
                # Floor must also be sane; fall back to 576 if not.
                case "$WFB_PAYLOAD_MIN" in
                    ''|*[!0-9]*) WFB_PAYLOAD_MIN=576 ;;
                esac
                [ "$WFB_PAYLOAD_MIN" -ge 576 ] && [ "$WFB_PAYLOAD_MIN" -le 4000 ] || WFB_PAYLOAD_MIN=576
                PAYLOAD_ARGS="--max-payload $WFB_PAYLOAD_MAX --payload-min $WFB_PAYLOAD_MIN"
            else
                log "WFB_PAYLOAD_MAX=$WFB_PAYLOAD_MAX out of [576,4000]; payload sizing off"
            fi ;;
    esac
    # Airtime guard (fec.airtime_max_pct in wfb-link.json; 0 = off, default 80).
    # Caps target bitrate so on-air airtime stays under N% of the channel — the
    # per-MCS pps/airslot ceiling. Also live-tunable via /set. The daemon
    # rejects an out-of-range value with exit 1, so validate at the config->CLI
    # boundary: a clean [0,100] / [0,200] integer is passed, anything else is
    # dropped so the daemon falls back to its safe compiled default (80 / 40us).
    AIRTIME_ARGS=""
    case "$WFB_AIRTIME_MAX_PCT" in
        ''|*[!0-9]*)
            log "WFB_AIRTIME_MAX_PCT='$WFB_AIRTIME_MAX_PCT' not numeric; using daemon default" ;;
        *)
            if [ "$WFB_AIRTIME_MAX_PCT" -ge 0 ] && [ "$WFB_AIRTIME_MAX_PCT" -le 100 ]; then
                AIRTIME_ARGS="--airtime-max-pct $WFB_AIRTIME_MAX_PCT"
                case "$WFB_AIRTIME_PREAMBLE_US" in
                    ''|*[!0-9]*) ;;                 # bad -> daemon default 40
                    *) [ "$WFB_AIRTIME_PREAMBLE_US" -ge 0 ] && [ "$WFB_AIRTIME_PREAMBLE_US" -le 200 ] && \
                           AIRTIME_ARGS="$AIRTIME_ARGS --airtime-preamble-us $WFB_AIRTIME_PREAMBLE_US" ;;
                esac
            else
                log "WFB_AIRTIME_MAX_PCT=$WFB_AIRTIME_MAX_PCT out of [0,100]; using daemon default"
            fi ;;
    esac

    # Bitrate floor (MCS0 setpoint). Validate the config->CLI boundary: a clean
    # [100,200000] integer is passed, anything else is dropped so the daemon
    # falls back to its safe compiled default (2200) rather than exit-1 bricking
    # the boot.
    BITRATE_MIN_ARGS=""
    case "$WFB_BITRATE_MIN" in
        ''|*[!0-9]*)
            log "WFB_BITRATE_MIN='$WFB_BITRATE_MIN' not numeric; using daemon default 2200" ;;
        *)
            if [ "$WFB_BITRATE_MIN" -ge 100 ] && [ "$WFB_BITRATE_MIN" -le 200000 ]; then
                BITRATE_MIN_ARGS="--bitrate-min $WFB_BITRATE_MIN"
            else
                log "WFB_BITRATE_MIN=$WFB_BITRATE_MIN out of [100,200000]; using daemon default 2200"
            fi ;;
    esac
    $LINK_CONTROLLER \
        --wfb 127.0.0.1:$WFB_CTRL \
        --venc "$WFB_VENC_HOST" \
        --safe-startup-bitrate $SAFE_BITRATE \
        --stats 0.0.0.0:$WFB_RX_FWD_PORT \
        --uplink-stats $WFB_UPLINK_RX_PORT \
        --failsafe $WFB_FAILSAFE_S \
        --wfb-iface "$WFB_IFACE" \
        --key-file "$KEY" \
        $PROBE_ARGS $LOG_ARGS $RECOVERY_ARGS $PAYLOAD_ARGS $AIRTIME_ARGS $BITRATE_MIN_ARGS \
        >> "$LOG" 2>&1 &
    echo $! > "$PID_LC"

    log "started (tx=$(cat $PID_TX) rx=$(cat $PID_RX) lc=$(cat $PID_LC)$(probe_enabled && echo " ptx=$(cat $PID_PTX)")$([ "$WFB_RECOVERY" = "1" ] && echo " rxr=$(cat $PID_RXR)"))"
}

stop_wfb() {
    log "stopping"
    for f in "$PID_LC" "$PID_PTX" "$PID_RXR" "$PID_RX" "$PID_TX"; do
        [ -f "$f" ] && { kill "$(cat $f)" 2>/dev/null; rm -f "$f"; }
    done
    sleep 0.5
    killall -q $WFB_PROCS 2>/dev/null
    # Legacy cleanup: pre-#70 images spawned a separate walkout_logger.sh (SD
    # logging is in-process in link_controller now). Reap any survivor so it
    # can't linger as an orphan across a stop/start.
    killall -q walkout_logger.sh 2>/dev/null
    rm -f /var/run/walkout_logger.pid 2>/dev/null
    sleep 0.3
    ip link set "$WFB_IFACE" down 2>/dev/null
    # Return the iface to AP mode (or whatever wlanmode is set to)
    IFACE="$WFB_IFACE" /usr/bin/adapter start >> "$LOG" 2>&1
    log "$WFB_IFACE restored via adapter"
}

status_wfb() {
    echo "wfbmode env: $(fw_get wfbmode 0)  probe: $(probe_enabled && echo on || echo off)  peek: $WFB_PEEK_PROFILE  (from wfb-link.json)"
    if command -v wfb-air >/dev/null 2>&1; then
        # All applets share comm 'wfb-air'; report per-role from the pid files
        # so a single dead applet is still visible (pidof wfb-air can't tell
        # them apart).
        echo "  (mega: applets share comm 'wfb-air' — per-role from pidfiles)"
        for rolepid in "video-tx:$PID_TX" "uplink-rx:$PID_RX" "link:$PID_LC" "probe-tx:$PID_PTX" "recovery-rx:$PID_RXR"; do
            role=${rolepid%%:*}; f=${rolepid#*:}
            if [ -f "$f" ] && kill -0 "$(cat "$f")" 2>/dev/null; then
                echo "  $role (wfb-air): $(cat "$f")"
            else
                echo "  $role (wfb-air): not running"
            fi
        done
    else
        for name in wfb_tx wfb_rx link_controller; do
            pid=$(pidof "$name" 2>/dev/null)
            echo "  $name: ${pid:-not running}"
        done
        if [ -f "$PID_PTX" ]; then
            ppid=$(cat "$PID_PTX")
            kill -0 "$ppid" 2>/dev/null \
                && echo "  probe wfb_tx: $ppid" \
                || echo "  probe wfb_tx: stale pidfile ($ppid)"
        fi
    fi
    echo "  sd logger: in-process in link_controller (log: $WFB_LOG (script), SD: $(grep -q ' /mnt/mmcblk0p1 ' /proc/mounts && echo present || echo absent), latest: $(ls -1d /mnt/mmcblk0p1/walkout/*/ 2>/dev/null | sort | tail -1 || echo none))"
    [ "$(fw_get wfbmode 0)" = "1" ] && command -v curl >/dev/null 2>&1 && \
        echo "  sd logger live: $(curl -s -m 2 http://127.0.0.1:8765/log/status 2>/dev/null || echo '(link_controller /log/status unreachable)')"
    echo "$WFB_IFACE:"
    iw dev "$WFB_IFACE" info 2>/dev/null | grep -E "type|channel|txpower" | sed 's/^/  /'
}

case "$1" in
    start)
        if is_enabled; then
            start_wfb
        else
            log "disabled (fw_setenv wfbmode 1 to enable)"
        fi
        ;;
    stop)    stop_wfb ;;
    restart) stop_wfb; sleep 0.5; start_wfb ;;
    status)  status_wfb ;;
    *)       echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
exit 0
