#!/bin/sh
# recovery-apfpv.sh — reference hook for the open recovery backdoor.
#
# link_controller fork+execs `recovery.apfpv_cmd` (default
# /etc/wfb/recovery-apfpv.sh) when the keyless recovery channel arms. This stub
# shows the contract; the REAL action belongs to the firmware/builder layer.
#
# Contract:
#   - Triggered by an UNAUTHENTICATED RF command — keep it to ONE safe, DEFERRED
#     action. Do NOT reboot here, do NOT touch keys, channel, or servos.
#   - Must be idempotent: the channel's arm/cooldown gate keeps it to one fire
#     per operator press, but a hostile flood can still re-run it every
#     cooldown window — re-arming the same flag must be harmless.
#   - Should be quick (link_controller waits on it synchronously).
#   - Exit 0 on success (surfaced as /status recovery.last_rc).
#
# Wire it to whatever your firmware uses to boot into AP-FPV next time, e.g.:
#
#   fw_setenv boot_mode apfpv   # OpenIPC u-boot env flag read by the init layer
#   sync
#
# The default below just drops a marker so the path is testable on a stock image.

set -e
MARKER="/tmp/recovery-apfpv-armed"
echo "armed at $(date 2>/dev/null || echo unknown)" > "$MARKER"

# --- replace the line below with the real firmware boot-mode switch ---
# fw_setenv boot_mode apfpv && sync

exit 0
