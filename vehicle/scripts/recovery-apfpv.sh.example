#!/bin/sh
# recovery-apfpv.sh — reference hook for the open recovery backdoor.
#
# link_controller fork+execs `recovery.apfpv_cmd` (default
# /etc/wfb/recovery-apfpv.sh) when the keyless recovery channel arms. This stub
# shows the contract; the REAL action belongs to the firmware/builder layer.
#
# Contract:
#   - Triggered by an UNAUTHENTICATED RF command — keep it to ONE safe, DEFERRED
#     action. Do NOT reboot here, do NOT touch keys, channel, or servos.
#   - Must be idempotent: the channel's arm/cooldown gate keeps it to one fire
#     per operator press, but a hostile flood can still re-run it every
#     cooldown window — re-arming the same flag must be harmless.
#   - Should be quick (link_controller waits on it synchronously).
#   - Exit 0 on success (surfaced as /status recovery.last_rc).
#
# Wire it to whatever your firmware uses to boot into AP-FPV next time.
#
# VERIFIED on OpenIPC ssc338q (Infinity6E, waybeam image): the boot mode is the
# u-boot env var `wfbmode`. wfbmode=1 -> S99wfb starts wfb broadcast; wfbmode!=1
# -> APFPV: S99wfb skips wfb, S95waybeam switches venc to udp:// output, and the
# box comes up as the `waybeam-03` AP (wlanmode=ap). So arming APFPV is just:
#
#   fw_setenv wfbmode 0 && sync
#
# Device-confirmed: recovery channel -> this hook -> reboot -> wlan0 type AP
# (ssid waybeam-03), venc outgoing.server=udp://127.0.0.1:5600, wfb absent.
#
# The active line below is the real action; swap it for a marker if you only
# want to smoke-test the recovery path on a bench image.

logger -t recovery "arming APFPV-next-boot (fw_setenv wfbmode 0)" 2>/dev/null
fw_setenv wfbmode 0
sync
exit 0

# --- smoke-test alternative (no real boot-mode change) ---
# echo "armed at $(date 2>/dev/null || echo unknown)" > /tmp/recovery-apfpv-armed
# exit 0
