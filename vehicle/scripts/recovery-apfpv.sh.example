#!/bin/sh
# recovery-apfpv.sh — reference hook for the Return-to-APFPV recovery action.
#
# link_controller fork+execs `recovery.apfpv_cmd` (default
# /etc/wfb/recovery-apfpv.sh) from TWO paths, both of which converge here:
#   - key 64 — the keyless/open (-xx) recovery backdoor (unauthenticated RF),
#     gated by recovery_dispatch()'s 3-frame-arm + arm_window_ms + cooldown_ms.
#   - key 20 — the AUTHENTICATED return_apfpv WCMD on the keyed uplink, gated by
#     cmd.allow_keys_mask + the 500 ms per-key burst-dedup.
# This stub shows the contract; the REAL action belongs to the firmware/builder.
#
# Contract (updated — see docs/protocols/recovery-backdoor.md):
#   - The action now ARMS APFPV-next-boot AND REBOOTS, so 1->0 actually completes
#     without a second manual step. The reboot is acceptable under the keyless
#     path's 3-frame-arm + arm_window + cooldown bound (a held button / flood
#     can't reboot-loop — one fire per arm, then a cooldown), and the keyed path
#     is additionally mask-gated + authenticated. Blast radius: a confirmed
#     recovery now reboots the vehicle (previously next-reboot-only).
#   - Must be idempotent: re-arming wfbmode=0 before the reboot lands is harmless.
#   - Should be quick to reach the reboot (link_controller waits synchronously;
#     the box is going down anyway).
#   - Exit 0 on success (surfaced as /status recovery.last_rc) if it returns
#     before the reboot tears the process down.
#
# VERIFIED on OpenIPC ssc338q (Infinity6E, waybeam image): the boot mode is the
# u-boot env var `wfbmode`. wfbmode=1 -> S99wfb starts wfb broadcast; wfbmode!=1
# -> APFPV: S99wfb skips wfb, S95waybeam switches venc to udp:// output, and the
# box comes up as the `waybeam-03` AP (wlanmode=ap). So returning to APFPV is:
#
#   fw_setenv wfbmode 0 && sync && reboot
#
# Device-confirmed: recovery channel -> this hook -> reboot -> wlan0 type AP
# (ssid waybeam-03), venc outgoing.server=udp://127.0.0.1:5600, wfb absent.
#
# The active line below is the real action; swap it for the bench marker (which
# does NOT reboot) if you only want to smoke-test the recovery path.

logger -t recovery "Return-to-APFPV: fw_setenv wfbmode 0 + reboot" 2>/dev/null
fw_setenv wfbmode 0 && sync && reboot
exit 0

# --- smoke-test alternative (no boot-mode change, no reboot) ---
# echo "armed at $(date 2>/dev/null || echo unknown)" > /tmp/recovery-apfpv-armed
# exit 0
