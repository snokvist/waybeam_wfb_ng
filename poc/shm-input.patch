+/* Compute (n - k) / k as a Q8.8 fixed-point ratio for auto-scale.
+ * Floored at 1 (≈ 0.004 in Q8.8) so ratios that round to zero parity
+ * (e.g. -k 4 -n 5 at actual_k=1 → round(0.25) = 0) still emit at least
+ * one parity on every partial block.  Capped at 255 to stay within
+ * Q8.8 encodeable range. */
+uint16_t Transmitter::compute_proportional_parity_q8(int k, int n)
+{
+    if (k <= 0 || n <= k)
+        return 1;
+
+    uint32_t num = (uint32_t)(n - k) * 256u;
+    uint32_t q8  = (num + (uint32_t)k / 2u) / (uint32_t)k;
+    if (q8 == 0)
+        q8 = 1;
+    if (q8 > 65535u)
+        q8 = 65535u;
+    return (uint16_t)q8;
+}
+
+void Transmitter::refresh_parity_ratio_if_auto(void)
+{
+    if (!parity_ratio_auto)
+        return;
+    if (fec_k <= 0 || fec_n <= 0)
+        return;
+    parity_ratio_q8 = compute_proportional_parity_q8(fec_k, fec_n);
+}
