+// C3 variable-k close: emit the currently-open FEC block with only the
+// fragments actually written, trimmed parity count, and no zero-padded
+// data packets on the wire.
+//
+// Semantics: the block is still FEC-encoded with the session's fec_k so
+// the existing RX (which waits for fec_k fragments) decodes normally via
+// parity substitution; we simply skip the wire-inject of the padding
+// slots. Parity count is capped at (fec_n - fec_k) and floored at
+// (fec_k - actual_k) so the receiver always collects enough fragments
+// to trigger its FEC path.
+//
+// Savings vs. the padding-based close path:
+//   - no wire inject of (fec_k - actual_k) zero-padded data packets
+//   - no wire inject of (fec_n - fec_k - parity_count) skipped parity
+//   - RX behaviour unchanged: same session keys, same block_idx sequence,
+//     same apply_fec logic (reconstructs FEC_ONLY slots as zeros)
+//
+// Returns false if no block is open (fragment_idx == 0).
+bool Transmitter::close_block_early(void)
+{
+    if (fragment_idx == 0)
+    {
+        return false;  // nothing open to close
+    }
+
+    uint8_t actual_k = fragment_idx;
+
+    // Plan the emission.  Two quantities matter:
+    //
+    //   parity_count     : how many parity packets we send on the wire.
+    //                      Hard-capped at (fec_n - fec_k); target is
+    //                      round(actual_k * parity_ratio_q8 / 256); the
+    //                      Q8.8 shift matches set_mbit's fixed-point.
+    //   padding_on_wire  : how many zero-padded data slots we additionally
+    //                      emit on the wire when (actual_k + parity_count)
+    //                      would fall short of fec_k.  Without this, RX
+    //                      never reaches has_fragments == fec_k and the
+    //                      block expires without decode.
+    //
+    // When (fec_k - actual_k) > (fec_n - fec_k) — i.e. the full-block
+    // parity budget is smaller than the shortfall to fec_k — we fall
+    // back to wire padding for the difference.  This keeps C3 correct
+    // for "light FEC" configs like -k 8 -n 12 where fec_k > 2*(fec_n-fec_k)
+    // and tiny partials can't reach the RX trigger on parity alone.
+    int parity_max     = fec_n - fec_k;
+    int parity_target  = (int)(((uint32_t)actual_k * (uint32_t)parity_ratio_q8 + 128u) >> 8);
+    int parity_count   = std::min(parity_max, std::max(0, parity_target));
+    int padding_on_wire = std::max(0, fec_k - (int)actual_k - parity_count);
+
+    // Fill the remaining data slots with FEC_ONLY markers (flags + zero
+    // payload) so the FEC encoder sees a full k-input matrix.  Emit the
+    // first `padding_on_wire` of them on the wire; the rest stay in
+    // memory only (RX reconstructs them from parity as FEC_ONLY zeros
+    // and suppresses them at send_to_socket).
+    int padding_emitted = 0;
+    while (fragment_idx < fec_k)
+    {
+        wpacket_hdr_t *packet_hdr = (wpacket_hdr_t*)block[fragment_idx];
+        packet_hdr->flags = WFB_PACKET_FEC_ONLY;
+        packet_hdr->packet_size = 0;
+        memset(block[fragment_idx] + sizeof(wpacket_hdr_t), '\0',
+               MAX_FEC_PAYLOAD - sizeof(wpacket_hdr_t));
+        if (padding_emitted < padding_on_wire)
+        {
+            send_block_fragment(sizeof(wpacket_hdr_t));
+            padding_emitted += 1;
+        }
+        fragment_idx += 1;
+    }
+
+    // FEC encode with the session's fec_k / fec_n (no change to the math)
+    zfex_status_code_t _rc = fec_encode_simd(fec_p, (const uint8_t**)block,
+                                             block + fec_k,
+                                             ZFEX_ROUND_UP_SIMD(max_packet_size));
+    assert(_rc == ZFEX_SC_OK);
+
+    set_mark(1);
+
+    // Emit only parity_count parity packets (fragment_idx fec_k .. fec_k+parity_count-1)
+    int emit_stop = fec_k + parity_count;
+    while (fragment_idx < emit_stop)
+    {
+        if (fec_delay > 0)
+        {
+            struct timespec t = { .tv_sec = (time_t)(fec_delay / 1000000),
+                                  .tv_nsec = (suseconds_t)(fec_delay % 1000000) * 1000 };
+            int rc = clock_nanosleep(CLOCK_MONOTONIC, 0, &t, NULL);
+            if(rc != 0 && rc != EINTR)
+            {
+                throw runtime_error(string_format("clock_nanosleep: %s", strerror(rc)));
+            }
+        }
+        send_block_fragment(max_packet_size);
+        fragment_idx += 1;
+    }
+
+    // Block emitted — reset counters for next block
+    block_idx += 1;
+    fragment_idx = 0;
+    max_packet_size = 0;
+
+    // Rotate session key periodically (same as send_packet's full-block close)
+    if (block_idx > MAX_BLOCK_IDX)
+    {
+        init_session(fec_k, fec_n);
+        for(int i = 0; i < fec_n - fec_k + 1; i++)
+        {
+            send_session_key();
+        }
+    }
+
+    return true;
+}
