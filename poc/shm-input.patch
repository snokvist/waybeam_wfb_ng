+int set_mbit(char *progname, int port, int argc, char **argv)
+{
+    int opt;
+    int enable = 1;
+    int ratio = 2;
+    cmd_req_t req = { .req_id = htonl(rand()), .cmd_id = CMD_SET_MBIT };
+    cmd_resp_t resp;
+
+    while ((opt = getopt(argc, argv, "e:r:h")) != -1)
+    {
+        switch (opt)
+        {
+        case 'e':
+            enable = atoi(optarg);
+            break;
+
+        case 'r':
+            ratio = atoi(optarg);
+            break;
+
+        default: /* '?' */
+            fprintf(stderr, "Usage: %s <port> %s [-e ENABLE(0|1)] [-r RATIO(0..255)]\n", progname, argv[0]);
+            fprintf(stderr, "Default: enable=%d, ratio=%d\n", enable, ratio);
+            fprintf(stderr, "  enable=1 closes FEC block on RTP M-bit (frame boundary)\n");
+            fprintf(stderr, "  ratio scales parity for partial blocks; 2 matches typical full-block ratio\n");
+            fprintf(stderr, "WFB-ng version %s\n", WFB_VERSION);
+            fprintf(stderr, "WFB-ng home page: <http://wfb-ng.org>\n");
+            return 1;
+        }
+    }
+
+    if (ratio < 0 || ratio > 255)
+    {
+        fprintf(stderr, "ratio must be 0..255\n");
+        return 1;
+    }
+    if (enable != 0 && enable != 1)
+    {
+        fprintf(stderr, "enable must be 0 or 1\n");
+        return 1;
+    }
+
+    req.u.cmd_set_mbit.enable = (uint8_t)enable;
+    req.u.cmd_set_mbit.parity_ratio = (uint8_t)ratio;
+
+    return send_command(port, req, offsetof(cmd_req_t, u) + sizeof(req.u.cmd_set_mbit), &resp);
+}
+
+int get_mbit(char *progname, int port, int argc, char **argv)
+{
+    cmd_req_t req = { .req_id = htonl(rand()), .cmd_id = CMD_GET_MBIT };
+    cmd_resp_t resp;
+
+    int rc = send_command(port, req, offsetof(cmd_req_t, u), &resp);
+
+    if (rc == 0)
+    {
+        printf("enable=%d\n"
+               "parity_ratio=%d\n",
+               resp.u.cmd_get_mbit.enable,
+               resp.u.cmd_get_mbit.parity_ratio);
+    }
+    return rc;
+}
