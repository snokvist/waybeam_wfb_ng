+int set_mbit(char *progname, int port, int argc, char **argv)
+{
+    int opt;
+    int enable = 1;
+    double ratio = 0.5;
+    cmd_req_t req = { .req_id = htonl(rand()), .cmd_id = CMD_SET_MBIT };
+    cmd_resp_t resp;
