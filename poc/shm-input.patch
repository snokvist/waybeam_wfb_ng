+    while ((opt = getopt(argc, argv, "e:r:h")) != -1)
+    {
+        char *endp;
+        switch (opt)
+        {
+        case 'e':
+        {
+            long v = strtol(optarg, &endp, 10);
+            if (*endp != '\0' || endp == optarg || (v != 0 && v != 1))
+            {
+                fprintf(stderr, "enable (-e) must be 0 or 1\n");
+                return 1;
+            }
+            enable = (int)v;
+            break;
+        }
+
+        case 'r':
+        {
+            double v = strtod(optarg, &endp);
+            if (*endp != '\0' || endp == optarg || !(v >= 0.0 && v < 256.0))
+            {
+                fprintf(stderr, "ratio (-r) must be a float in [0.0, 256.0)\n");
+                return 1;
+            }
+            ratio = v;
+            break;
+        }
+
+        default: /* '?' */
+            fprintf(stderr, "Usage: %s <port> %s [-e ENABLE(0|1)] [-r RATIO(float, 0..255.996)]\n", progname, argv[0]);
+            fprintf(stderr, "Default: enable=%d, ratio=%.2f\n", enable, ratio);
+            fprintf(stderr, "  enable=1 closes FEC block on RTP M-bit (frame boundary)\n");
+            fprintf(stderr, "  ratio scales parity:data for partial blocks; set to (n-k)/k of your\n");
+            fprintf(stderr, "  -k/-n config for proportional protection. Examples:\n");
+            fprintf(stderr, "    -k 8  -n 12 : ratio 0.5 (default when running default -k/-n)\n");
+            fprintf(stderr, "    -k 6  -n 18 : ratio 2.0\n");
+            fprintf(stderr, "    -k 10 -n 30 : ratio 2.0\n");
+            fprintf(stderr, "WFB-ng version %s\n", WFB_VERSION);
+            fprintf(stderr, "WFB-ng home page: <http://wfb-ng.org>\n");
+            return 1;
+        }
+    }
